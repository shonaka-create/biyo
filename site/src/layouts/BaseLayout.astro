---
// 全ページ共通レイアウト：SEOメタ・OGP・hreflang・JSON-LD・フォント・ヘッダー/フッター・計測フック
import { siteCommon, siteText } from '../content/site';
import { ui } from '../content/ui';
import { locales, hreflangMap, defaultLang, type Lang } from '../i18n/config';
import { localizePath, stripLocale } from '../i18n/utils';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';
import CookieConsent from '../components/CookieConsent.astro';
import '../styles/global.css';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  /** 追加のJSON-LD（ページ固有の構造化データ） */
  jsonLd?: object[];
}

const { lang, title, description, jsonLd = [] } = Astro.props;
const basePath = stripLocale(Astro.url.pathname);
const canonical = new URL(localizePath(basePath, lang), siteCommon.siteUrl).href;

// hreflang 代替URL（§10 / §12）
const alternates = locales.map((code) => ({
  code: hreflangMap[code],
  href: new URL(localizePath(basePath, code), siteCommon.siteUrl).href,
}));
const xDefaultHref = new URL(localizePath(basePath, defaultLang), siteCommon.siteUrl).href;

const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteCommon.brandName, // TODO: ブランド名確定後に更新
  url: siteCommon.siteUrl,
  email: siteCommon.email,
  areaServed: ['Gold Coast'],
  description: siteText[lang].tagline,
};
---

<!doctype html>
<html lang={hreflangMap[lang]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />

    <!-- hreflang（§10 / §12） -->
    {alternates.map((alt) => <link rel="alternate" hreflang={alt.code} href={alt.href} />)}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />

    <!-- OGP / Twitter Card（§12） -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/og-default.svg', siteCommon.siteUrl).href} />
    <!-- TODO: og-default は 1200×630 の実画像（PNG/JPG）に差し替え（§8.7） -->
    <meta property="og:site_name" content={siteCommon.brandName} />
    <meta property="og:locale" content={lang === 'ja' ? 'ja_JP' : 'en_AU'} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- フォント（§8.3）：display=swap -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&family=Noto+Sans+JP:wght@400;500;600&family=Shippori+Mincho:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- 構造化データ（§12） -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationLd)} />
    {jsonLd.map((ld) => <script type="application/ld+json" set:html={JSON.stringify(ld)} />)}

    <slot name="head" />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[60] focus:rounded-md focus:bg-surface focus:px-4 focus:py-2"
    >
      {ui[lang].common.skipToContent}
    </a>

    <Navbar lang={lang} />

    <main id="main">
      <slot />
    </main>

    <Footer lang={lang} />
    <StickyMobileCTA lang={lang} />
    <CookieConsent lang={lang} />

    <script>
      // スクロールリビール（§8.6）
      const reveals = document.querySelectorAll('.reveal');
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced) {
        reveals.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15 }
        );
        reveals.forEach((el) => io.observe(el));
      }

      // cta_click 計測（§13）
      document.querySelectorAll<HTMLElement>('[data-cta]').forEach((el) => {
        el.addEventListener('click', () => {
          window.gtag?.('event', 'cta_click', {
            cta_location: el.dataset.cta,
            cta_label: el.textContent?.trim(),
          });
          if (el.dataset.cta?.startsWith('plan-')) {
            window.gtag?.('event', 'plan_select', { plan: el.dataset.cta.replace('plan-', '') });
          }
        });
      });

      // scroll_depth 計測（25/50/75/100%）
      const sent = new Set<number>();
      window.addEventListener(
        'scroll',
        () => {
          const depth =
            ((window.scrollY + window.innerHeight) /
              document.documentElement.scrollHeight) *
            100;
          [25, 50, 75, 100].forEach((threshold) => {
            if (depth >= threshold && !sent.has(threshold)) {
              sent.add(threshold);
              window.gtag?.('event', 'scroll_depth', { percent: threshold });
            }
          });
        },
        { passive: true }
      );

      // outbound_click 計測
      document.querySelectorAll<HTMLAnchorElement>('a[target="_blank"]').forEach((a) => {
        a.addEventListener('click', () => {
          window.gtag?.('event', 'outbound_click', { url: a.href });
        });
      });
    </script>
  </body>
</html>
