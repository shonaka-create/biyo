---
// 私たちについて（§6.4）：2か国体制の物語・ミッション・チーム・対応エリア・価値観
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import CTABand from '../components/CTABand.astro';
import { team, strengths, finalCta } from '../content/copy.ja';
import { site } from '../content/site';

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: site.siteUrl },
    { '@type': 'ListItem', position: 2, name: '私たちについて', item: `${site.siteUrl}/about` },
  ],
};
---

<BaseLayout
  title={`私たちについて｜${site.brandName}`}
  description="日本とゴールドコーストにまたがる2人組のチーム。日本品質の制作・運用と、現地7年の信頼関係。私たちが「集客の成長パートナー」を始めた理由をお話しします。"
  jsonLd={[breadcrumbLd]}
>
  <section class="px-5 pb-16 pt-32 md:pt-40 lg:px-8">
    <div class="mx-auto max-w-[760px]">
      <SectionHeading
        label="About"
        heading="日本の品質を、現地の信頼で届ける。"
        lead="私たちは、日本とオーストラリア・ゴールドコーストにまたがる2人組のチームです。"
      />
      <div class="reveal mt-10 space-y-6 text-[15px] leading-loose text-ink-muted">
        <p>
          日本側は、Web制作・Instagram運用・集客の仕組み化・分析改善を担当。日本で磨いてきたマーケティングと制作のノウハウを、そのままオーストラリアのサロン様にお届けします。
        </p>
        <p>
          オーストラリア側は、ゴールドコースト在住7年。営業・現地での折衝・撮影の連携・そして何より、オーナー様との信頼関係づくりと顧客成功を担当します。
        </p>
        <p>
          技術力の高い日本人オーナーのサロンが、デジタル集客の壁——英語、現地市場の理解、誰に任せればいいのか分からない不安——でつまずいているのを、私たちは現地でたくさん見てきました。
        </p>
        <p>
          だから私たちは、「日本品質の実行力 × 現地の信頼」という形でこの事業を始めました。単発の制作や投稿代行ではなく、集客の輪全体を回し続ける“成長パートナー”として、サロンの隣に立ち続けます。
        </p>
      </div>
    </div>
  </section>

  <section class="bg-surface-cream px-5 py-20 md:py-28 lg:px-8">
    <div class="mx-auto max-w-[1200px]">
      <SectionHeading label="Team" heading="チーム" align="center" />
      <div class="mx-auto mt-12 grid max-w-[880px] gap-8 md:grid-cols-2">
        {
          team.members.map((member) => (
            <div class="reveal rounded-lg bg-surface p-7 text-center">
              <ImagePlaceholder
                slot_id={member.slot}
                label={`${member.role} ポートレート`}
                ratio="1/1"
                class="mx-auto w-40 rounded-full"
              />
              <h2 class="mt-5 font-sans text-lg font-semibold">{member.name}</h2>
              <p class="mt-1 text-sm text-brand">{member.role}</p>
              <p class="mt-1 text-xs text-ink-muted">{member.location}</p>
              <p class="mt-4 text-sm text-ink-muted">{member.message}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="px-5 py-20 md:py-28 lg:px-8">
    <div class="mx-auto max-w-[1200px]">
      <SectionHeading label="Values" heading="私たちが大切にしていること" align="center" />
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          strengths.items.map((item, i) => (
            <div class="reveal rounded-lg border border-line bg-surface p-7">
              <span class="font-display text-2xl text-brand" aria-hidden="true">
                {String(i + 1).padStart(2, '0')}
              </span>
              <h2 class="mt-3 font-sans text-base font-semibold">{item.title}</h2>
              <p class="mt-3 text-sm text-ink-muted">{item.body}</p>
            </div>
          ))
        }
      </div>
      <p class="reveal mt-10 text-center text-sm text-ink-muted">対応エリア：{site.areas}</p>
    </div>
  </section>

  <CTABand
    heading={finalCta.heading}
    sub={finalCta.sub}
    ctaLabel={finalCta.cta.label}
    ctaHref={finalCta.cta.href}
    ctaLocation="about-band"
  />
</BaseLayout>
