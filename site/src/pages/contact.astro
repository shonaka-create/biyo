---
// お問い合わせ・無料相談（§6.6）：フォーム + 予約ツール埋め込み + 連絡先
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ContactForm from '../components/ContactForm.astro';
import { site } from '../content/site';

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: site.siteUrl },
    { '@type': 'ListItem', position: 2, name: '無料相談', item: `${site.siteUrl}/contact` },
  ],
};
---

<BaseLayout
  title={`無料相談のご予約｜${site.brandName}`}
  description="30分の無料相談（オンラインまたは対面）をご予約いただけます。現状のヒアリングと、できることのご提案だけでも歓迎です。無理な営業はいたしません。"
  jsonLd={[breadcrumbLd]}
>
  <section class="px-5 pb-24 pt-32 md:pt-40 lg:px-8">
    <div class="mx-auto max-w-[1200px]">
      <SectionHeading
        label="Contact"
        heading="まずは30分、無料でお話ししませんか。"
        lead="現状のヒアリングと、できることのご提案だけでも大丈夫です。フォーム送信後、1〜2営業日以内にご返信します。"
      />

      <div class="mt-12 grid gap-12 lg:grid-cols-[1fr_360px]">
        <div class="reveal relative rounded-xl border border-line bg-surface p-7 md:p-10">
          <ContactForm />
        </div>

        <aside class="space-y-8">
          <div class="reveal rounded-lg bg-surface-cream p-7">
            <h2 class="font-sans text-base font-semibold">日程をその場で押さえたい方へ</h2>
            <p class="mt-3 text-sm text-ink-muted">
              カレンダーから直接、無料相談の日時をご予約いただけます。
            </p>
            {
              site.bookingUrl ? (
                <a
                  href={site.bookingUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-5 inline-flex h-12 w-full items-center justify-center rounded-md border border-brand px-6 font-medium text-brand transition hover:bg-brand-soft"
                  data-cta="booking-tool"
                >
                  予約カレンダーを開く
                </a>
              ) : (
                <div class="mt-5 rounded-md border border-dashed border-line bg-canvas p-5 text-center text-xs text-ink-muted">
                  {/* TODO: Calendly / TimeRex / Spir のURL確定後、site.ts の bookingUrl に設定すると
                      ここに予約ボタン（または埋め込みウィジェット）が表示されます */}
                  予約ツール埋め込み予定（Calendly / TimeRex / Spir）
                </div>
              )
            }
          </div>

          <div class="reveal rounded-lg border border-line bg-surface p-7">
            <h2 class="font-sans text-base font-semibold">その他の連絡方法</h2>
            <ul class="mt-4 space-y-3 text-sm text-ink-muted">
              <li>
                メール：<a href={`mailto:${site.email}`} class="text-brand underline underline-offset-2">{site.email}</a>
              </li>
              <li>
                Instagram DM：<a
                  href={site.instagramUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-brand underline underline-offset-2">@アカウント名</a
                >
                <!-- TODO: Instagramアカウント名確定後に差し替え -->
              </li>
            </ul>
            <p class="mt-4 text-xs text-ink-muted">対応エリア：{site.areas}</p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
