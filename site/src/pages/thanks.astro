---
// フォーム送信完了画面（§4.3）。自動返信メールはフォームサービス側で設定（TODO）。
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
import { site } from '../content/site';
---

<BaseLayout
  title={`送信完了｜${site.brandName}`}
  description="お問い合わせありがとうございます。1〜2営業日以内にご返信いたします。"
>
  <section class="flex min-h-[70vh] items-center px-5 pb-24 pt-32 lg:px-8">
    <div class="mx-auto max-w-[600px] text-center">
      <svg
        class="mx-auto h-14 w-14 text-success"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="10"></circle>
        <path d="m8 12.5 2.5 2.5L16 9"></path>
      </svg>
      <h1 class="mt-6 text-[32px]">送信ありがとうございます。</h1>
      <p class="mt-5 text-ink-muted">
        内容を確認のうえ、<strong class="text-ink">1〜2営業日以内</strong>にメールでご返信いたします。<br />
        確認の自動返信メールが届かない場合は、迷惑メールフォルダをご確認いただくか、<a
          href={`mailto:${site.email}`}
          class="text-brand underline underline-offset-2">{site.email}</a
        >まで直接ご連絡ください。
      </p>
      <CTAButton href="/" variant="secondary" ctaLocation="thanks" class="mt-10">
        トップページへ戻る
      </CTAButton>
    </div>
  </section>
</BaseLayout>
