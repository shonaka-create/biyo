---
// 事例詳細（§6.3）：課題 → 施策 → 結果のケーススタディ構造。事例追加は works.ts に追記するだけ。
import BaseLayout from '../../layouts/BaseLayout.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import CTABand from '../../components/CTABand.astro';
import { works } from '../../content/works';
import { finalCta } from '../../content/copy.ja';
import { site } from '../../content/site';

export function getStaticPaths() {
  return works.map((work) => ({ params: { slug: work.slug }, props: { work } }));
}

const { work } = Astro.props;

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: site.siteUrl },
    { '@type': 'ListItem', position: 2, name: '実績・事例', item: `${site.siteUrl}/works` },
    { '@type': 'ListItem', position: 3, name: work.name, item: `${site.siteUrl}/works/${work.slug}` },
  ],
};
---

<BaseLayout
  title={`${work.name}の事例｜${site.brandName}`}
  description={work.summary}
  jsonLd={[breadcrumbLd]}
>
  <article class="px-5 pb-24 pt-32 md:pt-40 lg:px-8">
    <div class="mx-auto max-w-[880px]">
      <nav aria-label="パンくず" class="mb-8 text-xs text-ink-muted">
        <a href="/" class="hover:text-brand">ホーム</a>
        <span class="mx-2" aria-hidden="true">/</span>
        <a href="/works" class="hover:text-brand">実績・事例</a>
        <span class="mx-2" aria-hidden="true">/</span>
        <span aria-current="page">{work.name}</span>
      </nav>

      <p class="text-sm tracking-widest text-brand">{work.industry}｜{work.area}</p>
      <h1 class="mt-2 text-[32px] md:text-[40px]">{work.name}</h1>
      <ul class="mt-5 flex flex-wrap gap-2">
        {
          work.services.map((s) => (
            <li class="rounded-full bg-brand-soft px-3 py-1 text-xs text-brand-strong">{s}</li>
          ))
        }
      </ul>

      <div class="reveal mt-10">
        <ImagePlaceholder slot_id={work.thumbSlot} label={`${work.name} メインビジュアル`} ratio="16/9" />
      </div>

      <div class="mt-14 space-y-12">
        <section class="reveal">
          <h2 class="border-b border-line pb-3 text-2xl">課題</h2>
          <p class="mt-5 text-[15px] leading-loose text-ink-muted">{work.challenge}</p>
        </section>

        <section class="reveal">
          <h2 class="border-b border-line pb-3 text-2xl">施策</h2>
          <ul class="mt-5 space-y-3">
            {
              work.approach.map((a) => (
                <li class="flex items-start gap-3 text-[15px] text-ink-muted">
                  <svg
                    class="mt-1.5 h-4 w-4 shrink-0 text-brand"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <path d="m5 13 4 4L19 7" />
                  </svg>
                  {a}
                </li>
              ))
            }
          </ul>
        </section>

        <section class="reveal">
          <h2 class="border-b border-line pb-3 text-2xl">結果</h2>
          <p class="mt-5 text-[15px] leading-loose text-ink-muted">{work.result}</p>
        </section>

        <section class="reveal">
          <h2 class="border-b border-line pb-3 text-2xl">制作物</h2>
          <div class="mt-6 grid gap-6 sm:grid-cols-2">
            {
              work.detailSlots.map((d) => (
                <ImagePlaceholder
                  slot_id={d.id}
                  label={d.label}
                  ratio={d.ratio.replace(':', '/')}
                />
              ))
            }
          </div>
        </section>
      </div>
    </div>
  </article>

  <CTABand
    heading="あなたのサロンでも、同じ仕組みを。"
    sub={finalCta.sub}
    ctaLabel={finalCta.cta.label}
    ctaHref={finalCta.cta.href}
    ctaLocation="work-detail-band"
  />
</BaseLayout>
