---
import { works } from '../../content/works';
import WorkDetailPage from '../../components/pages/WorkDetailPage.astro';

export function getStaticPaths() {
  return works.ja.map((work) => ({ params: { slug: work.slug }, props: { work } }));
}

const { work } = Astro.props;
---
<WorkDetailPage lang="ja" work={work} />
