---
// 実績一覧（§6.3）
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import CTABand from '../../components/CTABand.astro';
import { works } from '../../content/works';
import { finalCta } from '../../content/copy.ja';
import { site } from '../../content/site';

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: site.siteUrl },
    { '@type': 'ListItem', position: 2, name: '実績・事例', item: `${site.siteUrl}/works` },
  ],
};
---

<BaseLayout
  title={`実績・事例｜${site.brandName}`}
  description="ゴールドコースト・ブリスベンのサロン様との実績。Webサイト制作・予約導線・レビュー埋め込み・MEO整備・Instagram運用の事例をご紹介します。"
  jsonLd={[breadcrumbLd]}
>
  <section class="px-5 pb-16 pt-32 md:pt-40 lg:px-8">
    <div class="mx-auto max-w-[1200px]">
      <SectionHeading
        label="Works"
        heading="実績・事例"
        lead="課題 → 施策 → 結果の流れで、実際の取り組みをご紹介します。"
      />
    </div>
  </section>

  <section class="px-5 pb-24 lg:px-8">
    <div class="mx-auto grid max-w-[1200px] gap-8 md:grid-cols-2">
      {
        works.map((work) => (
          <a
            href={`/works/${work.slug}`}
            class="reveal group block rounded-lg border border-line bg-surface p-6 transition hover:border-brand"
          >
            <ImagePlaceholder slot_id={work.thumbSlot} label={`${work.name} サムネイル`} ratio="4/3" />
            <p class="mt-5 text-xs tracking-widest text-ink-muted">
              {work.industry}｜{work.area}
            </p>
            <h2 class="mt-1 font-sans text-lg font-semibold transition group-hover:text-brand">
              {work.name}
            </h2>
            <p class="mt-2 text-sm text-ink-muted">{work.summary}</p>
            <ul class="mt-4 flex flex-wrap gap-2">
              {work.services.map((s) => (
                <li class="rounded-full bg-brand-soft px-3 py-1 text-xs text-brand-strong">{s}</li>
              ))}
            </ul>
          </a>
        ))
      }
    </div>
  </section>

  <CTABand
    heading={finalCta.heading}
    sub={finalCta.sub}
    ctaLabel={finalCta.cta.label}
    ctaHref={finalCta.cta.href}
    ctaLocation="works-band"
  />
</BaseLayout>
