---
// 料金詳細（§6.2）：松竹梅＋オプション＋料金の考え方＋料金FAQ
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PlanCard from '../components/PlanCard.astro';
import Accordion from '../components/Accordion.astro';
import CTABand from '../components/CTABand.astro';
import { plans, planNotes, options, pricingFaq } from '../content/plans';
import { finalCta } from '../content/copy.ja';
import { site } from '../content/site';

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: site.siteUrl },
    { '@type': 'ListItem', position: 2, name: '料金', item: `${site.siteUrl}/pricing` },
  ],
};
---

<BaseLayout
  title={`料金プラン｜${site.brandName}`}
  description="サロン集客サポートの料金一覧。梅（立ち上げ）・竹（集客）・松（ブランド成長）の3プランと、撮影同行などのオプション。すべて〈初期構築＋月額＋オプション〉の透明な三層構造です。"
  jsonLd={[breadcrumbLd]}
>
  <section class="px-5 pb-16 pt-32 md:pt-40 lg:px-8">
    <div class="mx-auto max-w-[1200px]">
      <SectionHeading
        label="Pricing"
        heading="料金の考え方は、シンプルな三層です。"
        lead="〈初期構築（一回）＋ 月額（継続）＋ オプション(都度)〉。最初に土台を作り、毎月の運用で輪を回し、必要なときだけオプションを足す——分かりやすさを大切にしています。"
      />
    </div>
  </section>

  <section class="px-5 pb-20 lg:px-8">
    <div class="mx-auto max-w-[1200px]">
      <div class="grid gap-8 lg:grid-cols-3 lg:gap-6">
        {plans.map((plan) => <PlanCard plan={plan} />)}
      </div>
      <div class="reveal mt-8 space-y-1 text-center text-sm text-ink-muted">
        {planNotes.map((n) => <p>{n}</p>)}
      </div>
    </div>
  </section>

  <section class="bg-surface px-5 py-20 md:py-28 lg:px-8">
    <div class="mx-auto max-w-[880px]">
      <SectionHeading
        label="Options"
        heading="オプション（共通・都度）"
        lead="どのプランにも追加できます。"
      />
      <div class="reveal mt-10 overflow-hidden rounded-lg border border-line">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="border-b border-line bg-surface-cream">
              <th scope="col" class="px-5 py-3.5 font-medium">オプション</th>
              <th scope="col" class="px-5 py-3.5 font-medium">料金</th>
              <th scope="col" class="hidden px-5 py-3.5 font-medium md:table-cell">備考</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-line bg-canvas">
            {
              options.map((o) => (
                <tr>
                  <td class="px-5 py-4 font-medium">{o.name}</td>
                  <td class="px-5 py-4 text-ink-muted">{o.price}</td>
                  <td class="hidden px-5 py-4 text-ink-muted md:table-cell">{o.note}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="px-5 py-20 md:py-28 lg:px-8">
    <div class="mx-auto max-w-[880px]">
      <SectionHeading label="FAQ" heading="料金についてよくある質問" />
      <div class="reveal mt-10">
        <Accordion items={pricingFaq} analyticsPrefix="pricing" />
      </div>
    </div>
  </section>

  <CTABand
    heading="どのプランが合うか、一緒に考えます。"
    sub="現状をお聞きして、最適なプランを率直にご提案します。梅で十分な場合は、そうお伝えします。"
    ctaLabel={finalCta.cta.label}
    ctaHref={finalCta.cta.href}
    ctaLocation="pricing-band"
  />
</BaseLayout>
