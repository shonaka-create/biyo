---
// figure-funnel（§6.1 S7）：集客ファネル図。
// 「どの段階で何を支援するか」を、上から下へ narrowing するファネルで可視化する。
// 上4段＝お客様の旅（認知→検討・予約→リピート・再来→紹介・レビュー）、
// 最下部に「横断（全段階を回し続ける運用）」を全幅バンドで配置。
// 紹介・レビューが次の認知へ還流する＝輪、という当サイトの基本メッセージも明記する。
import { copy } from '../content/copy';
import { ui } from '../content/ui';
import type { Lang } from '../i18n/config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const stages = copy[lang].services.stages;
const loopback = ui[lang].home.serviceFunnelLoop;

// 旅の4段（ファネル本体）と、横断の運用（全幅バンド）を分ける。
const journey = stages.slice(0, 4);
const span = stages[4];

// 段ごとの幅と色（上＝広く淡い緑 → 下＝狭く濃い緑）。
const widths = ['100%', '90%', '80%', '70%'];
const tones = ['#6f9385', '#52806f', '#3d6a5a', '#2f5d4f'];
---

<div class="funnel" role="img" aria-label={copy[lang].services.lead}>
  {
    journey.map((s, i) => (
      <>
        <div class="funnel__tier" style={`--w:${widths[i]}; --c:${tones[i]}`}>
          <div class="funnel__stage">
            <span class="funnel__stage-label">{s.stage}</span>
            <span class="funnel__stage-summary">{s.summary}</span>
          </div>
          <ul class="funnel__items">
            {s.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
        {i < journey.length - 1 && (
          <span class="funnel__arrow" aria-hidden="true" />
        )}
      </>
    ))
  }

  <p class="funnel__loop"><span aria-hidden="true">↻</span>{loopback}</p>

  <div class="funnel__span">
    <span class="funnel__span-label">{span.stage}</span>
    <div class="funnel__span-body">
      <span class="funnel__span-summary">{span.summary}</span>
      <ul>
        {span.items.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </div>
</div>

<style>
  .funnel {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* 各段：モバイルは全幅・縦積み、md以上で narrowing して横並び */
  .funnel__tier {
    width: 100%;
    max-width: 920px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: var(--radius-md);
    background: var(--color-surface);
    border: 1px solid var(--color-line);
  }

  .funnel__stage {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.15rem;
    padding: 1rem 1.25rem;
    background: var(--c);
    color: #fff;
  }

  .funnel__stage-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    opacity: 0.85;
  }

  .funnel__stage-summary {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .funnel__items {
    flex: 1;
    display: grid;
    gap: 0.4rem;
    padding: 1rem 1.25rem;
    margin: 0;
    list-style: none;
  }

  .funnel__items li {
    position: relative;
    padding-left: 1rem;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
  }

  .funnel__items li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 5px;
    height: 5px;
    border-radius: 9999px;
    background: var(--color-brand);
  }

  .funnel__arrow {
    width: 0;
    height: 0;
    margin: 0.4rem 0;
    border-left: 8px solid transparent;
    border-right: 8px solid transparent;
    border-top: 9px solid var(--color-brand);
    opacity: 0.55;
  }

  .funnel__loop {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
    padding: 0.55rem 1.1rem;
    border-radius: 9999px;
    background: var(--color-brand-soft);
    color: var(--color-brand-strong);
    font-size: 0.8125rem;
    font-weight: 600;
    text-align: center;
  }

  .funnel__loop span {
    font-size: 1.05rem;
    line-height: 1;
  }

  /* 横断：全幅で全段階を支える運用バンド */
  .funnel__span {
    width: 100%;
    max-width: 920px;
    margin-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.1rem 1.25rem;
    border-radius: var(--radius-md);
    border: 1px dashed var(--color-brand);
    background: var(--color-canvas);
  }

  .funnel__span-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--color-brand-strong);
  }

  .funnel__span-summary {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
  }

  .funnel__span-body ul {
    margin: 0.35rem 0 0;
    padding: 0;
    list-style: none;
  }

  .funnel__span-body li {
    position: relative;
    padding-left: 1rem;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
  }

  .funnel__span-body li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 5px;
    height: 5px;
    border-radius: 9999px;
    background: var(--color-brand);
  }

  @media (min-width: 768px) {
    .funnel__tier {
      width: var(--w);
      flex-direction: row;
      align-items: stretch;
    }

    .funnel__stage {
      width: 220px;
      flex-shrink: 0;
    }

    .funnel__items {
      grid-template-columns: 1fr 1fr;
      align-content: center;
    }
  }
</style>
