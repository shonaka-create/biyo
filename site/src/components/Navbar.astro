---
// ヘッダー（§7.1）：初期透過 → スクロールで背景＋境界線＋縮小。モバイルはフルスクリーンメニュー。
// モバイルメニューはヘッダーの外（body直下）に配置する。ヘッダー内に置くと
//  ・#site-header.at-top のテキスト白化ルールを継承して文字が読めなくなる
//  ・ヘッダーのスタッキング/トランジションの影響で背景が透けてフッターが透過する
// といった不具合が起きるため、独立した最前面オーバーレイとして扱う。
import { siteCommon, navText } from '../content/site';
import { localizePath } from '../i18n/utils';
import type { Lang } from '../i18n/config';
import CTAButton from './CTAButton.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const nav = navText[lang];
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-300"
>
  <div
    class="mx-auto flex h-[72px] max-w-[1200px] items-center justify-between px-5 transition-all duration-300 lg:px-8"
    id="header-inner"
  >
    <a href={localizePath('/', lang)} class="font-display text-xl tracking-wide text-ink">
      {siteCommon.brandName}
    </a>

    <nav class="hidden items-center gap-8 lg:flex" aria-label="Global">
      {
        nav.links.map((link) => (
          <a
            href={localizePath(link.path, lang)}
            class="text-[15px] text-ink transition hover:text-brand"
          >
            {link.label}
          </a>
        ))
      }
      <LanguageSwitcher lang={lang} />
      <CTAButton href={nav.cta.path} lang={lang} variant="primary" ctaLocation="header" class="h-11 px-5 text-[15px]">
        {nav.cta.label}
      </CTAButton>
    </nav>

    <button
      id="menu-toggle"
      class="flex h-11 w-11 items-center justify-center lg:hidden"
      aria-label="メニューを開く"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="h-6 w-6 text-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16" />
      </svg>
    </button>
  </div>
</header>

<!-- モバイル フルスクリーンメニュー（ヘッダー外・最前面の独立オーバーレイ） -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] hidden flex-col overflow-y-auto overscroll-contain bg-canvas text-ink lg:hidden"
  role="dialog"
  aria-modal="true"
  aria-label={siteCommon.brandName}
>
  <div class="flex h-[72px] shrink-0 items-center justify-between px-5">
    <a href={localizePath('/', lang)} class="font-display text-xl tracking-wide text-ink" data-menu-link>
      {siteCommon.brandName}
    </a>
    <button id="menu-close" class="-mr-2 flex h-11 w-11 items-center justify-center text-ink" aria-label="メニューを閉じる">
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>
  </div>

  <nav class="flex flex-1 flex-col px-6 pb-10 pt-2" aria-label="モバイルナビゲーション">
    {
      nav.links.map((link) => (
        <a
          href={localizePath(link.path, lang)}
          class="border-b border-line py-4 text-lg text-ink"
          data-menu-link
        >
          {link.label}
        </a>
      ))
    }
    <CTAButton href={nav.cta.path} lang={lang} variant="primary" ctaLocation="mobile-menu" class="mt-8 w-full">
      {nav.cta.label}
    </CTAButton>
    <LanguageSwitcher lang={lang} variant="stack" class="mt-8" />
  </nav>
</div>

<script>
  const header = document.getElementById('site-header')!;
  const inner = document.getElementById('header-inner')!;
  const onScroll = () => {
    const scrolled = window.scrollY > 24;
    header.classList.toggle('bg-canvas/95', scrolled);
    header.classList.toggle('backdrop-blur', scrolled);
    header.classList.toggle('border-b', scrolled);
    header.classList.toggle('border-line', scrolled);
    inner.classList.toggle('h-[64px]', scrolled);
    inner.classList.toggle('h-[72px]', !scrolled);
    // 最上部（透過）ではヒーロー画像の上に重なるため文字・アイコンを白に
    header.classList.toggle('at-top', !scrolled);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  const toggle = document.getElementById('menu-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const closeBtn = document.getElementById('menu-close')!;

  const setMenu = (open: boolean) => {
    toggle.setAttribute('aria-expanded', String(open));
    menu.classList.toggle('hidden', !open);
    menu.classList.toggle('flex', open);
    document.body.style.overflow = open ? 'hidden' : '';
  };

  toggle.addEventListener('click', () => setMenu(toggle.getAttribute('aria-expanded') !== 'true'));
  closeBtn.addEventListener('click', () => setMenu(false));
  // メニュー内リンクをタップしたら閉じる（同一ページ内アンカー遷移でも確実に閉じる）
  menu.querySelectorAll('[data-menu-link]').forEach((el) =>
    el.addEventListener('click', () => setMenu(false))
  );
  // Escキーで閉じる
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') setMenu(false);
  });
</script>
