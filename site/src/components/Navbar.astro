---
// ヘッダー（§7.1）：初期透過 → スクロールで背景＋境界線＋縮小。モバイルはフルスクリーンメニュー。
// モバイルメニューはヘッダーの外（body直下）に配置する。ヘッダー内に置くと
//  ・#site-header.at-top のテキスト白化ルールを継承して文字が読めなくなる
//  ・ヘッダーのスタッキング/トランジションの影響で背景が透けてフッターが透過する
// といった不具合が起きるため、独立した最前面オーバーレイとして扱う。
import { siteCommon, navText } from '../content/site';
import { ui } from '../content/ui';
import { localizePath } from '../i18n/utils';
import type { Lang } from '../i18n/config';
import CTAButton from './CTAButton.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: Lang;
  /** 透過ヘッダー（ダークなヒーロー画像の上に重ねるページのみ true）。
   *  下層ページなど明るい背景のページで true にすると、最上部で白文字になり
   *  ヘッダーが背景に溶けて見えなくなるため、既定は false（常に背景付き）。 */
  transparentHeader?: boolean;
}
const { lang, transparentHeader = false } = Astro.props;
const nav = navText[lang];
const u = ui[lang].common;
---

<header
  id="site-header"
  data-transparent={transparentHeader ? 'true' : 'false'}
  class:list={[
    'fixed inset-x-0 top-0 z-50 transition-all duration-300',
    !transparentHeader && 'bg-canvas/95 backdrop-blur border-b border-line',
  ]}
>
  <div
    class:list={[
      'mx-auto flex max-w-[1200px] items-center justify-between px-5 transition-all duration-300 lg:px-8',
      transparentHeader ? 'h-[72px]' : 'h-[64px]',
    ]}
    id="header-inner"
  >
    <a href={localizePath('/', lang)} class="flex items-center" aria-label={siteCommon.brandName}>
      <img
        data-logo
        src="/images/logo.png"
        alt={siteCommon.brandName}
        class="h-10 w-auto transition-all duration-300"
        width="40"
        height="40"
      />
    </a>

    <nav class="hidden items-center gap-6 lg:flex" aria-label="Global">
      {
        nav.links.map((link) => (
          <a
            href={localizePath(link.path, lang)}
            class="text-[15px] text-ink transition hover:text-brand"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={`mailto:${siteCommon.email}`}
        class="inline-flex h-10 items-center gap-2 rounded-full border border-current px-4 text-[14px] text-ink transition hover:text-brand"
        aria-label={u.emailCta}
        title={u.emailCta}
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <rect x="3" y="5" width="18" height="14" rx="2"></rect>
          <path d="m3 7 9 6 9-6"></path>
        </svg>
        <span>{u.emailCta}</span>
      </a>
      <LanguageSwitcher lang={lang} />
      <CTAButton href={nav.cta.path} lang={lang} variant="primary" ctaLocation="header" class="h-11 px-5 text-[15px]">
        {nav.cta.label}
      </CTAButton>
    </nav>

    <button
      id="menu-toggle"
      class="flex h-11 w-11 items-center justify-center lg:hidden"
      aria-label="メニューを開く"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="h-6 w-6 text-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16" />
      </svg>
    </button>
  </div>
</header>

<!-- モバイル フルスクリーンメニュー（ヘッダー外・最前面の独立オーバーレイ） -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] hidden flex-col overflow-y-auto overscroll-contain bg-canvas text-ink lg:hidden"
  role="dialog"
  aria-modal="true"
  aria-label={siteCommon.brandName}
>
  <div class="flex h-[72px] shrink-0 items-center justify-between px-5">
    <a href={localizePath('/', lang)} class="flex items-center" aria-label={siteCommon.brandName} data-menu-link>
      <img src="/images/logo.png" alt={siteCommon.brandName} class="h-10 w-auto" width="40" height="40" />
    </a>
    <button id="menu-close" class="-mr-2 flex h-11 w-11 items-center justify-center text-ink" aria-label="メニューを閉じる">
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>
  </div>

  <nav class="flex flex-1 flex-col px-6 pb-10 pt-2" aria-label="モバイルナビゲーション">
    {
      nav.links.map((link) => (
        <a
          href={localizePath(link.path, lang)}
          class="border-b border-line py-4 text-lg text-ink"
          data-menu-link
        >
          {link.label}
        </a>
      ))
    }
    <CTAButton href={nav.cta.path} lang={lang} variant="primary" ctaLocation="mobile-menu" class="mt-8 w-full">
      {nav.cta.label}
    </CTAButton>
    <a
      href={`mailto:${siteCommon.email}`}
      class="mt-3 inline-flex h-12 w-full items-center justify-center gap-2 rounded-md border border-brand px-6 font-medium text-brand transition hover:bg-brand-soft"
      data-menu-link
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <rect x="3" y="5" width="18" height="14" rx="2"></rect>
        <path d="m3 7 9 6 9-6"></path>
      </svg>
      {u.emailCta}
    </a>
    <LanguageSwitcher lang={lang} variant="stack" class="mt-8" />
  </nav>
</div>

<style>
  /* 透過ヘッダー（トップ最上部）ではダークなヒーロー画像に重なるため、
     モノクロ・透過背景のロゴを白く反転させて視認性を確保する。 */
  #site-header.at-top [data-logo] {
    filter: brightness(0) invert(1);
  }
</style>

<script>
  const header = document.getElementById('site-header')!;
  const inner = document.getElementById('header-inner')!;
  // 透過ヘッダーのページ（トップ）のみ、スクロール量で透過⇄背景付きを切り替える。
  // それ以外のページは常に背景付き（マークアップ側で適用済み）なので何もしない。
  if (header.dataset.transparent === 'true') {
    const onScroll = () => {
      const scrolled = window.scrollY > 24;
      header.classList.toggle('bg-canvas/95', scrolled);
      header.classList.toggle('backdrop-blur', scrolled);
      header.classList.toggle('border-b', scrolled);
      header.classList.toggle('border-line', scrolled);
      inner.classList.toggle('h-[64px]', scrolled);
      inner.classList.toggle('h-[72px]', !scrolled);
      // 最上部（透過）ではヒーロー画像の上に重なるため文字・アイコンを白に
      header.classList.toggle('at-top', !scrolled);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  const toggle = document.getElementById('menu-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const closeBtn = document.getElementById('menu-close')!;

  const setMenu = (open: boolean) => {
    toggle.setAttribute('aria-expanded', String(open));
    menu.classList.toggle('hidden', !open);
    menu.classList.toggle('flex', open);
    document.body.style.overflow = open ? 'hidden' : '';
  };

  toggle.addEventListener('click', () => setMenu(toggle.getAttribute('aria-expanded') !== 'true'));
  closeBtn.addEventListener('click', () => setMenu(false));
  // メニュー内リンクをタップしたら閉じる（同一ページ内アンカー遷移でも確実に閉じる）
  menu.querySelectorAll('[data-menu-link]').forEach((el) =>
    el.addEventListener('click', () => setMenu(false))
  );
  // Escキーで閉じる
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') setMenu(false);
  });
</script>
