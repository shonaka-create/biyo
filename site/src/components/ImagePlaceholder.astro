---
// 画像プレースホルダー（§8.7）
// 実画像差し替え時は data-image-slot 属性を目印に <img> / <Image> へ置換する。
interface Props {
  /** 画像スロット識別子（例: "hero-main", "case-thumb-mai-lashes"） */
  slot_id: string;
  /** 用途ラベル（枠の中に表示） */
  label: string;
  /** アスペクト比。例: "16/9", "4/3", "1/1", "4/5" */
  ratio?: string;
  class?: string;
}

const { slot_id, label, ratio = '16/9', class: className = '' } = Astro.props;
---

<div
  class={`flex items-center justify-center rounded-lg border border-line bg-surface-cream ${className}`}
  style={`aspect-ratio: ${ratio};`}
  data-image-slot={slot_id}
  role="img"
  aria-label={`画像プレースホルダー: ${label}`}
>
  <div class="px-4 text-center text-ink-muted">
    <svg
      class="mx-auto mb-2 h-6 w-6 opacity-60"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      aria-hidden="true"
    >
      <rect x="3" y="5" width="18" height="14" rx="2"></rect>
      <circle cx="8.5" cy="10" r="1.5"></circle>
      <path d="m21 15-4.35-4.35a1 1 0 0 0-1.42 0L7 19"></path>
    </svg>
    <p class="text-xs leading-relaxed">{label}<br /><span class="opacity-70">({slot_id} / {ratio})</span></p>
  </div>
</div>
