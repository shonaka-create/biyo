---
// 画像プレースホルダー（§8.7）
// 実画像差し替え時は data-image-slot 属性を目印に <img> / <Image> へ置換する。
// src を渡せば任意の画像を表示。省略時はスロット名から適切なフリー画像を自動選択。
interface Props {
  /** 画像スロット識別子（例: "hero-main", "case-thumb-mai-lashes"） */
  slot_id: string;
  /** 用途ラベル（alt テキストに使用） */
  label: string;
  /** アスペクト比。例: "16/9", "4/3", "1/1", "4/5" */
  ratio?: string;
  /** 実画像 URL（省略時はフリー画像を自動使用） */
  src?: string;
  class?: string;
}

const { slot_id, label, ratio = '16/9', src, class: className = '' } = Astro.props;

// スロット名からカテゴリーを判定して適切な Unsplash 画像を選ぶ
const SLOT_IMAGE_MAP: Record<string, string> = {
  'hero-main':            'https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=900&q=80&fit=crop',
  'logo-strip-1':         'https://picsum.photos/seed/logo1/600/200',
  'logo-strip-2':         'https://picsum.photos/seed/logo2/600/200',
  'logo-strip-3':         'https://picsum.photos/seed/logo3/600/200',
  'logo-strip-4':         'https://picsum.photos/seed/logo4/600/200',
  'case-thumb-mai-lashes':'https://images.unsplash.com/photo-1516975080664-ed2fc6a32937?w=800&q=80&fit=crop',
  'case-thumb-mimu':      'https://images.unsplash.com/photo-1604654894610-df63bc536371?w=800&q=80&fit=crop',
  'testimonial-avatar-1': 'https://images.unsplash.com/photo-1487412720507-e7ab37603c6f?w=200&q=80&fit=crop&crop=face',
  'testimonial-avatar-2': 'https://images.unsplash.com/photo-1529626455594-4ff0802cfb7e?w=200&q=80&fit=crop&crop=face',
  'testimonial-avatar-3': 'https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=200&q=80&fit=crop&crop=face',
  'testimonial-avatar-4': 'https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?w=200&q=80&fit=crop&crop=face',
  'team-portrait-jp':     'https://images.unsplash.com/photo-1487412720507-e7ab37603c6f?w=400&q=80&fit=crop&crop=face',
  'team-portrait-au':     'https://images.unsplash.com/photo-1529626455594-4ff0802cfb7e?w=400&q=80&fit=crop&crop=face',
  'case-detail-mai-1':    'https://images.unsplash.com/photo-1547887538-047f15b4e8ce?w=1200&q=80&fit=crop',
  'case-detail-mai-2':    'https://images.unsplash.com/photo-1516975080664-ed2fc6a32937?w=1200&q=80&fit=crop',
  'case-detail-mai-3':    'https://images.unsplash.com/photo-1596462502278-27bfdc403348?w=1200&q=80&fit=crop',
  'case-detail-mimu-1':   'https://images.unsplash.com/photo-1604654894610-df63bc536371?w=800&q=80&fit=crop',
};

// スロット名プレフィックスによるフォールバック
function getFallbackSrc(id: string): string {
  if (id.startsWith('portrait-') || id.startsWith('testimonial-avatar-')) {
    return `https://picsum.photos/seed/${id}/400/400`;
  }
  if (id.startsWith('logo-strip-')) {
    return `https://picsum.photos/seed/${id}/600/200`;
  }
  if (id.startsWith('case-detail-')) {
    return `https://picsum.photos/seed/${id}/1200/675`;
  }
  return `https://picsum.photos/seed/${id}/800/600`;
}

const imgSrc = src ?? SLOT_IMAGE_MAP[slot_id] ?? getFallbackSrc(slot_id);
---

<div
  class={`overflow-hidden rounded-lg ${className}`}
  style={`aspect-ratio: ${ratio};`}
  data-image-slot={slot_id}
>
  <img
    src={imgSrc}
    alt={label}
    class="h-full w-full object-cover"
    loading="lazy"
    decoding="async"
  />
</div>
