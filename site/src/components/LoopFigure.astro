---
// figure-loop（§6.1 S5）：集客のループ図（フライホイール）
// 中央＝来店・施術（オーナー様の領分）、外周＝私たちが運用する4ステージ。
// テキストはHTMLで描画（SVGテキストの拡大ボケ／字形の歪みを回避）し、軌道はCSSで回転。
// ホバー／フォーカスで各ステージの「伝えたいこと」を開く。
import { ui } from '../content/ui';
import type { Lang } from '../i18n/config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang].figures.loop;

// 上・右・下・左の4ステージ（時計回り）
const placements = ['is-top', 'is-right', 'is-bottom', 'is-left'];
const nodes = t.nodes.map((n, i) => ({ ...n, place: placements[i] }));
---

<figure
  class="rounded-xl border border-line bg-surface p-6 md:p-10"
  data-figure="figure-loop"
>
  <p class="sr-only">{t.desc}</p>

  <div class="loop" role="img" aria-label={t.desc}>
    <!-- 循環の軌道（CSSで回転） -->
    <div class="loop__orbit" aria-hidden="true">
      <span class="loop__arrow loop__arrow--ne"></span>
      <span class="loop__arrow loop__arrow--se"></span>
      <span class="loop__arrow loop__arrow--sw"></span>
      <span class="loop__arrow loop__arrow--nw"></span>
    </div>

    <!-- レビュー還流の注記 -->
    <p class="loop__reflow" aria-hidden="true">{t.reflow}</p>

    <!-- 外周ステージ（私たちが運用） -->
    {
      nodes.map((n) => (
        <div class={`loop__node ${n.place}`} tabindex="0">
          <span class="loop__label">{n.label}</span>
          <span class="loop__sub">{n.sub}</span>
          <span class="loop__detail">{n.detail}</span>
        </div>
      ))
    }

    <!-- 中央：来店・施術（クライアント領域） -->
    <div class="loop__center">
      <span class="loop__center-title">{t.centerTitle}</span>
      <span class="loop__center-sub">{t.centerSub}</span>
    </div>
  </div>

  <!-- 凡例 -->
  <figcaption class="mt-6 border-t border-line pt-4">
    <div class="flex flex-wrap justify-center gap-x-8 gap-y-2 text-xs">
      <span class="inline-flex items-center gap-2">
        <span class="inline-block h-3 w-3 rounded-sm border border-brand bg-brand-soft" aria-hidden="true"></span>
        {t.legendOurs}
      </span>
      <span class="inline-flex items-center gap-2">
        <span class="inline-block h-3 w-3 rounded-full border-2 border-accent bg-surface-cream" aria-hidden="true"></span>
        {t.legendClient}
      </span>
    </div>
    <p class="mt-3 text-center text-xs text-ink-muted">
      {t.caption}
    </p>
  </figcaption>
</figure>

<style>
  /* ───────────────────────────────────────────────────────────
     モバイル既定：円形フライホイールはSPで重なり崩れるため、
     縦並びのカード列（中央＝ハブを先頭）にフォールバックする。
     600px以上で従来の円形レイアウトへ切り替える（下部のmedia）。
     ─────────────────────────────────────────────────────────── */
  .loop {
    position: relative;
    margin-inline: auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  /* 装飾の軌道・還流注記はSPでは非表示（凡例で意味は補える） */
  .loop__orbit,
  .loop__reflow {
    display: none;
  }

  /* 外周ステージ → SPでは全幅カードとして縦積み */
  .loop__node {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    padding: 0.85rem 1rem;
    border-radius: 12px;
    background: var(--color-brand-soft);
    border: 1.5px solid var(--color-brand);
    text-align: center;
    outline: none;
  }
  /* 縦並びの並び順：ハブ → 認知 → 検討 → リピート → 紹介 */
  .loop__node.is-top { order: 1; }
  .loop__node.is-right { order: 2; }
  .loop__node.is-bottom { order: 3; }
  .loop__node.is-left { order: 4; }

  /* ステージ間の循環を示す下向き矢印（SPのみ） */
  .loop__node:not(.is-left)::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -0.55rem;
    width: 0;
    height: 0;
    transform: translateX(-50%);
    border-left: 6px solid transparent;
    border-right: 6px solid transparent;
    border-top: 7px solid var(--color-brand);
    opacity: 0.5;
  }

  .loop__label {
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--color-brand-strong);
  }
  .loop__sub {
    font-size: 0.78rem;
    line-height: 1.3;
    color: var(--color-ink-muted);
  }

  /* 詳細：SPではホバー不可なので常時表示 */
  .loop__detail {
    display: block;
    margin-top: 0.4rem;
    font-size: 0.8rem;
    line-height: 1.45;
    color: var(--color-ink);
  }

  /* 中央：クライアント領域 → SPでは先頭のハブカード */
  .loop__center {
    order: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    padding: 0.95rem 1rem;
    border-radius: 12px;
    background: var(--color-surface-cream);
    border: 2px solid var(--color-accent);
    text-align: center;
  }
  .loop__center-title {
    font-size: 1.1875rem;
    font-weight: 600;
    color: var(--color-ink);
  }
  .loop__center-sub {
    font-size: 0.82rem;
    color: var(--color-accent-strong);
  }

  @keyframes loop-spin {
    to { transform: rotate(360deg); }
  }

  /* ───────────────────────────────────────────────────────────
     ≥600px：円形フライホイールレイアウト
     ─────────────────────────────────────────────────────────── */
  @media (min-width: 600px) {
    .loop {
      max-width: 480px;
      aspect-ratio: 1 / 1;
      display: block;
      gap: 0;
    }

    /* 軌道：破線リングをゆっくり回転させて循環を表現 */
    .loop__orbit {
      display: block;
      position: absolute;
      inset: 8%;
      border-radius: 50%;
      border: 2px dashed var(--color-line);
      animation: loop-spin 40s linear infinite;
    }

    .loop__arrow {
      position: absolute;
      width: 0;
      height: 0;
      border-style: solid;
      /* 右向き三角（時計回りの進行方向に回転して配置） */
      border-width: 5px 0 5px 9px;
      border-color: transparent transparent transparent var(--color-brand);
    }
    /* 円周上の45°位置（破線リング上）に配置し、進行方向（時計回り）へ回転 */
    .loop__arrow--ne { left: 85.4%; top: 14.6%; transform: translate(-50%, -50%) rotate(45deg); }
    .loop__arrow--se { left: 85.4%; top: 85.4%; transform: translate(-50%, -50%) rotate(135deg); }
    .loop__arrow--sw { left: 14.6%; top: 85.4%; transform: translate(-50%, -50%) rotate(225deg); }
    .loop__arrow--nw { left: 14.6%; top: 14.6%; transform: translate(-50%, -50%) rotate(315deg); }

    .loop__reflow {
      display: block;
      position: absolute;
      top: -0.25rem;
      left: 0;
      max-width: 30%;
      font-size: clamp(0.68rem, 2.2vw, 0.78rem);
      line-height: 1.3;
      color: var(--color-ink-muted);
    }

    /* 外周ステージ → 円周上に絶対配置 */
    .loop__node {
      position: absolute;
      width: clamp(8.5rem, 32%, 11rem);
      transform: translate(-50%, -50%);
      gap: 0.15rem;
      padding: 0.7rem 0.6rem;
      cursor: default;
      transition:
        transform 0.25s ease,
        box-shadow 0.25s ease,
        background 0.25s ease;
    }
    .loop__node.is-top { left: 50%; top: 8%; order: 0; }
    .loop__node.is-right { left: 92%; top: 50%; order: 0; }
    .loop__node.is-bottom { left: 50%; top: 92%; order: 0; }
    .loop__node.is-left { left: 8%; top: 50%; order: 0; }

    /* SP用の矢印は非表示 */
    .loop__node::after { content: none; }

    .loop__label { font-size: clamp(0.95rem, 3.2vw, 1.125rem); }
    .loop__sub { font-size: clamp(0.7rem, 2.4vw, 0.78rem); line-height: 1.25; }

    /* ホバー／フォーカスで開く詳細 */
    .loop__detail {
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      margin-top: 0;
      font-size: clamp(0.72rem, 2.4vw, 0.8rem);
      line-height: 1.4;
      transition:
        max-height 0.3s ease,
        opacity 0.25s ease,
        margin-top 0.3s ease;
    }

    .loop__node:hover,
    .loop__node:focus-visible {
      transform: translate(-50%, -50%) scale(1.04);
      background: var(--color-surface);
      box-shadow: 0 10px 28px -12px rgb(0 0 0 / 0.35);
      z-index: 5;
    }
    .loop__node:hover .loop__detail,
    .loop__node:focus-visible .loop__detail {
      max-height: 8rem;
      opacity: 1;
      margin-top: 0.45rem;
    }

    /* 中央：クライアント領域 → 円形ハブ */
    .loop__center {
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      width: 30%;
      aspect-ratio: 1 / 1;
      border-radius: 50%;
      gap: 0.2rem;
      padding: 0.5rem;
    }
    .loop__center-title { font-size: clamp(0.95rem, 3.4vw, 1.25rem); }
    .loop__center-sub { font-size: clamp(0.7rem, 2.4vw, 0.82rem); }
  }

  @media (prefers-reduced-motion: reduce) {
    .loop__orbit { animation: none; }
  }
</style>
