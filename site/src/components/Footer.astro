---
// フッター（§7.2）：4カラム、ink系の落ち着いたトーン。言語切替を最下部に設置（§10）。
import { siteCommon, siteText, navText } from '../content/site';
import { ui } from '../content/ui';
import { localizePath } from '../i18n/utils';
import type { Lang } from '../i18n/config';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const nav = navText[lang];
const t = ui[lang].footer;
const text = siteText[lang];
---

<footer class="bg-ink text-canvas">
  <div class="mx-auto grid max-w-[1200px] gap-10 px-5 py-16 md:grid-cols-2 lg:grid-cols-4 lg:px-8">
    <div>
      <p class="font-display text-xl">{siteCommon.brandName}</p>
      <p class="mt-3 text-sm leading-relaxed opacity-70">{text.tagline}</p>
    </div>

    <nav aria-label="Footer">
      <p class="mb-4 text-sm font-medium tracking-widest opacity-60">{t.sitemap}</p>
      <ul class="space-y-2 text-sm">
        {
          nav.links.map((link) => (
            <li>
              <a href={localizePath(link.path, lang)} class="opacity-80 transition hover:opacity-100">
                {link.label}
              </a>
            </li>
          ))
        }
        <li>
          <a href={localizePath('/contact', lang)} class="opacity-80 transition hover:opacity-100">{t.freeConsult}</a>
        </li>
      </ul>
    </nav>

    <div>
      <p class="mb-4 text-sm font-medium tracking-widest opacity-60">{t.contact}</p>
      <p class="text-sm opacity-80">{t.areasPrefix}{text.areas}</p>
      <a href={`mailto:${siteCommon.email}`} class="mt-2 inline-block text-sm opacity-80 transition hover:opacity-100">
        {siteCommon.email}
      </a>
    </div>

    <div>
      <p class="mb-4 text-sm font-medium tracking-widest opacity-60">{t.follow}</p>
      <a
        href={siteCommon.instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm opacity-80 transition hover:opacity-100"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="5"></rect>
          <circle cx="12" cy="12" r="4"></circle>
          <circle cx="17.2" cy="6.8" r="0.8" fill="currentColor" stroke="none"></circle>
        </svg>
        Instagram
      </a>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="mx-auto flex max-w-[1200px] flex-col items-start justify-between gap-4 px-5 py-6 text-xs opacity-60 md:flex-row md:items-center lg:px-8">
      <p>{text.copyright}</p>
      <div class="flex items-center gap-6">
        <a href={localizePath('/privacy', lang)} class="transition hover:opacity-100">{t.privacy}</a>
        <LanguageSwitcher lang={lang} tone="dark" class="opacity-100" />
      </div>
    </div>
  </div>
</footer>
