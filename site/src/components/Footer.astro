---
// フッター（§7.2）：4カラム、ink系の落ち着いたトーン
import { nav, site } from '../content/site';
---

<footer class="bg-ink text-canvas">
  <div class="mx-auto grid max-w-[1200px] gap-10 px-5 py-16 md:grid-cols-2 lg:grid-cols-4 lg:px-8">
    <div>
      <p class="font-display text-xl">{site.brandName}</p>
      <p class="mt-3 text-sm leading-relaxed opacity-70">{site.tagline}</p>
    </div>

    <nav aria-label="フッターナビゲーション">
      <p class="mb-4 text-sm font-medium tracking-widest opacity-60">SITEMAP</p>
      <ul class="space-y-2 text-sm">
        {
          nav.links.map((link) => (
            <li>
              <a href={link.href} class="opacity-80 transition hover:opacity-100">
                {link.label}
              </a>
            </li>
          ))
        }
        <li>
          <a href="/contact" class="opacity-80 transition hover:opacity-100">無料相談</a>
        </li>
      </ul>
    </nav>

    <div>
      <p class="mb-4 text-sm font-medium tracking-widest opacity-60">CONTACT</p>
      <p class="text-sm opacity-80">対応エリア：{site.areas}</p>
      <a href={`mailto:${site.email}`} class="mt-2 inline-block text-sm opacity-80 transition hover:opacity-100">
        {site.email}
      </a>
    </div>

    <div>
      <p class="mb-4 text-sm font-medium tracking-widest opacity-60">FOLLOW</p>
      <a
        href={site.instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm opacity-80 transition hover:opacity-100"
        data-analytics="outbound_click"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="5"></rect>
          <circle cx="12" cy="12" r="4"></circle>
          <circle cx="17.2" cy="6.8" r="0.8" fill="currentColor" stroke="none"></circle>
        </svg>
        Instagram
      </a>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="mx-auto flex max-w-[1200px] flex-col items-start justify-between gap-3 px-5 py-6 text-xs opacity-60 md:flex-row md:items-center lg:px-8">
      <p>{site.copyright}</p>
      <div class="flex gap-6">
        <a href="/privacy" class="transition hover:opacity-100">プライバシーポリシー</a>
        <!-- TODO: 将来の言語切替（EN）はここに追加（§10） -->
      </div>
    </div>
  </div>
</footer>
