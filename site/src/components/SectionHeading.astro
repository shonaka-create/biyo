---
// セクション見出し（§8.5）：スモールラベル + 見出し + リード文
interface Props {
  label?: string;
  heading: string;
  lead?: string;
  align?: 'left' | 'center';
  id?: string;
}

const { label, heading, lead, align = 'left', id } = Astro.props;
const alignClass = align === 'center' ? 'text-center mx-auto' : '';
---

<div class={`reveal max-w-[760px] ${alignClass}`} id={id}>
  {
    label && (
      <p class="mb-3 text-sm font-medium tracking-[0.18em] text-brand uppercase">
        {label}
      </p>
    )
  }
  <h2 class="text-[28px] leading-[1.3] md:text-[32px]">{heading}</h2>
  {lead && <p class="mt-5 text-[17px] text-ink-muted">{lead}</p>}
</div>
