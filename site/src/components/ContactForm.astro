---
// 無料相談フォーム（§4.3 / §7.4）
// 送信先は FORM_ENDPOINT（Formspree / Basin 等）。未設定の間はデモモードとして成功画面のみ表示。
// TODO: フォームサービス契約後にエンドポイントを設定し、自動返信メールをサービス側で設定する。
// TODO: reCAPTCHA v3 のサイトキー取得後、送信処理にトークン付与を追加する（§4.3）。
import { ui } from '../content/ui';
import { localizePath } from '../i18n/utils';
import type { Lang } from '../i18n/config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang].form;
const privacyHref = localizePath('/privacy', lang);
const thanksHref = localizePath('/thanks', lang);
const FORM_ENDPOINT = ''; // 例: 'https://formspree.io/f/xxxxxxx'
---

<form
  id="contact-form"
  class="space-y-6"
  method="POST"
  action={FORM_ENDPOINT || undefined}
  data-endpoint={FORM_ENDPOINT}
  data-thanks={thanksHref}
  novalidate
>
  <!-- honeypot（スパム対策・視覚的に隠す） -->
  <div class="absolute -left-[9999px]" aria-hidden="true">
    <label for="company-website">{t.honeypotLabel}</label>
    <input type="text" id="company-website" name="company-website" tabindex="-1" autocomplete="off" />
  </div>

  <div class="grid gap-6 md:grid-cols-2">
    <div>
      <label for="name" class="mb-2 block text-sm font-medium">
        {t.name} <span class="text-accent">{t.required}</span>
      </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        autocomplete="name"
        class="h-12 w-full rounded-md border border-line bg-surface px-4 text-base focus:border-brand"
      />
    </div>
    <div>
      <label for="shop" class="mb-2 block text-sm font-medium">
        {t.shop} <span class="text-accent">{t.required}</span>
      </label>
      <input
        type="text"
        id="shop"
        name="shop"
        required
        autocomplete="organization"
        class="h-12 w-full rounded-md border border-line bg-surface px-4 text-base focus:border-brand"
      />
    </div>
  </div>

  <div>
    <label for="email" class="mb-2 block text-sm font-medium">
      {t.email} <span class="text-accent">{t.required}</span>
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      autocomplete="email"
      class="h-12 w-full rounded-md border border-line bg-surface px-4 text-base focus:border-brand"
    />
  </div>

  <div class="grid gap-6 md:grid-cols-2">
    <div>
      <label for="location" class="mb-2 block text-sm font-medium">{t.location}</label>
      <select
        id="location"
        name="location"
        class="h-12 w-full rounded-md border border-line bg-surface px-4 text-base focus:border-brand"
      >
        <option value="">{t.locationSelect}</option>
        <option value="gold-coast">{t.locGc}</option>
        <option value="gc-surrounds">{t.locBrisbane}</option>
        <option value="other">{t.locOther}</option>
      </select>
    </div>
    <div>
      <label for="plan" class="mb-2 block text-sm font-medium">{t.planInterest}</label>
      <select
        id="plan"
        name="plan"
        class="h-12 w-full rounded-md border border-line bg-surface px-4 text-base focus:border-brand"
      >
        <option value="">{t.planUndecided}</option>
        <option value="sns-a">{t.planA}</option>
        <option value="sns-b">{t.planB}</option>
        <option value="sns-c">{t.planC}</option>
        <option value="site">{t.planSite}</option>
      </select>
    </div>
  </div>

  <div>
    <label for="sns" class="mb-2 block text-sm font-medium">{t.sns}</label>
    <input
      type="url"
      id="sns"
      name="sns"
      placeholder="https://"
      class="h-12 w-full rounded-md border border-line bg-surface px-4 text-base focus:border-brand"
    />
  </div>

  <div>
    <label for="message" class="mb-2 block text-sm font-medium">{t.message}</label>
    <textarea
      id="message"
      name="message"
      rows="5"
      placeholder={t.messagePlaceholder}
      class="w-full rounded-md border border-line bg-surface px-4 py-3 text-base focus:border-brand"></textarea>
  </div>

  <p id="form-error" class="hidden text-sm text-accent-strong" role="alert">
    {t.error}
  </p>

  <button
    type="submit"
    id="form-submit"
    data-label={t.submit}
    data-submitting={t.submitting}
    class="h-12 w-full rounded-md bg-accent px-6 font-medium text-white transition duration-300 hover:bg-accent-strong disabled:opacity-60 md:w-auto md:px-12"
    data-cta="contact-form"
  >
    {t.submit}
  </button>
  <p class="text-xs text-ink-muted">
    {t.privacyNote1}<a href={privacyHref} class="underline underline-offset-2">{t.privacyNoteLink}</a>{t.privacyNote2}
  </p>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('form-submit') as HTMLButtonElement;
  const errorEl = document.getElementById('form-error')!;

  // 料金カードからの遷移（?plan=sns-b 等）でプランを自動選択（§6.1 S8）
  const planParam = new URLSearchParams(location.search).get('plan');
  if (planParam) {
    const select = document.getElementById('plan') as HTMLSelectElement;
    if ([...select.options].some((o) => o.value === planParam)) select.value = planParam;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    // honeypot：入力があればボットとみなし黙って終了
    if ((form.elements.namedItem('company-website') as HTMLInputElement).value) return;

    window.gtag?.('event', 'form_submit', { form_id: 'contact' });
    submitBtn.disabled = true;
    submitBtn.textContent = submitBtn.dataset.submitting!;

    const endpoint = form.dataset.endpoint;
    try {
      if (endpoint) {
        const res = await fetch(endpoint, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (!res.ok) throw new Error(`status ${res.status}`);
      }
      // TODO: エンドポイント未設定の間はデモとして成功扱い（本番前に必ず設定）
      window.gtag?.('event', 'form_success', { form_id: 'contact' });
      location.href = form.dataset.thanks!;
    } catch {
      errorEl.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = submitBtn.dataset.label!;
    }
  });
</script>
