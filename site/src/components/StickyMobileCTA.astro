---
// モバイル下部追従CTA（§4.2）。ヒーロー通過後に表示。
import { nav } from '../content/site';
---

<div
  id="sticky-cta"
  class="fixed inset-x-0 bottom-0 z-40 translate-y-full border-t border-line bg-canvas/95 p-3 backdrop-blur transition-transform duration-300 lg:hidden"
>
  <a
    href={nav.cta.href}
    class="flex h-12 w-full items-center justify-center rounded-md bg-accent font-medium text-white transition hover:bg-accent-strong"
    data-cta="sticky-mobile"
  >
    {nav.cta.label}
  </a>
</div>

<script>
  const bar = document.getElementById('sticky-cta')!;
  const onScroll = () => {
    bar.classList.toggle('translate-y-full', window.scrollY < window.innerHeight * 0.7);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
