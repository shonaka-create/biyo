---
// モバイル下部追従CTA（§4.2）。ヒーロー通過後に表示。
import { navText, siteCommon } from '../content/site';
import { ui } from '../content/ui';
import { localizePath } from '../i18n/utils';
import type { Lang } from '../i18n/config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const cta = navText[lang].cta;
const emailCta = ui[lang].common.emailCta;
const isExternal = cta.path.startsWith('http://') || cta.path.startsWith('https://');
const resolvedPath = isExternal ? cta.path : localizePath(cta.path, lang);
---

<div
  id="sticky-cta"
  class="fixed inset-x-0 bottom-0 z-40 translate-y-full space-y-2 border-t border-line bg-canvas/95 p-3 backdrop-blur transition-transform duration-300 lg:hidden"
>
  <a
    href={resolvedPath}
    class="flex h-12 w-full items-center justify-center rounded-md bg-accent font-medium text-white transition hover:bg-accent-strong"
    data-cta="sticky-mobile"
    target={isExternal ? '_blank' : undefined}
    rel={isExternal ? 'noopener noreferrer' : undefined}
  >
    {cta.label}
  </a>
  <a
    href={`mailto:${siteCommon.email}`}
    class="flex h-12 w-full items-center justify-center gap-2 rounded-md border border-current font-medium text-ink transition hover:text-brand"
    data-cta="sticky-mobile-email"
  >
    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <rect x="3" y="5" width="18" height="14" rx="2"></rect>
      <path d="m3 7 9 6 9-6"></path>
    </svg>
    {emailCta}
  </a>
</div>

<script>
  const bar = document.getElementById('sticky-cta')!;
  const onScroll = () => {
    bar.classList.toggle('translate-y-full', window.scrollY < window.innerHeight * 0.7);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
