---
// 導入フロー ステッパー（§6.1 S9 / §8.5）：番号・タイトル・1文
interface Props {
  items: { title: string; body: string }[];
}

const { items } = Astro.props;
---

<ol class="grid gap-6 md:grid-cols-5">
  {
    items.map((step, i) => (
      <li class="reveal relative rounded-lg border border-line bg-surface p-6">
        <span class="font-display text-3xl text-brand" aria-hidden="true">
          {String(i + 1).padStart(2, '0')}
        </span>
        <h3 class="mt-3 font-sans text-base font-semibold">{step.title}</h3>
        <p class="mt-2 text-sm text-ink-muted">{step.body}</p>
      </li>
    ))
  }
</ol>
