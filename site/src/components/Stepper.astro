---
// 導入フロー ステッパー（§6.1 S9 / §8.5）：番号バッジ・接続線・タイトル・1文
interface Props {
  items: { title: string; body: string }[];
}

const { items } = Astro.props;
---

<ol class="stepper">
  {
    items.map((step, i) => (
      <li class="step reveal">
        <div class="step__head">
          <span class="step__num font-display" aria-hidden="true">
            {String(i + 1).padStart(2, '0')}
          </span>
        </div>
        <div class="step__card">
          <h3 class="font-sans text-base font-semibold">{step.title}</h3>
          <p class="mt-2 text-sm text-ink-muted">{step.body}</p>
        </div>
      </li>
    ))
  }
</ol>

<style>
  .stepper {
    display: grid;
    gap: 1.5rem;
  }

  .step {
    position: relative;
    display: flex;
    flex-direction: column;
    text-align: center;
  }

  .step__head {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .step__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 9999px;
    background: var(--color-brand);
    color: #fff;
    font-size: 1.125rem;
    line-height: 1;
    letter-spacing: 0.02em;
    box-shadow: 0 8px 18px -10px rgba(47, 93, 79, 0.7);
  }

  /* 接続線：各ステップを順番でつなぐ */
  .step:not(:last-child)::after {
    content: '';
    position: absolute;
    z-index: 0;
    background: var(--color-line);
  }

  .step__card {
    flex: 1;
    border-radius: 0.75rem;
    border: 1px solid var(--color-line);
    background: var(--color-surface);
    padding: 1.25rem 1.5rem;
    text-align: left;
  }

  /* モバイル：縦のレール */
  @media (max-width: 767px) {
    .step:not(:last-child)::after {
      top: 3rem;
      left: 50%;
      transform: translateX(-50%);
      width: 2px;
      height: calc(100% - 1.5rem);
    }
  }

  /* デスクトップ：横に並べてバッジ同士を線でつなぐ */
  @media (min-width: 768px) {
    .stepper {
      grid-template-columns: repeat(5, minmax(0, 1fr));
    }

    .step:not(:last-child)::after {
      top: 1.5rem;
      left: calc(50% + 1.5rem);
      width: calc(100% - 1.5rem);
      height: 2px;
    }
  }
</style>
