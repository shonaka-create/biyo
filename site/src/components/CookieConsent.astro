---
// Cookie同意バナー（§13 / §15）。同意した場合のみ GA4 を読み込む。
---

<div
  id="cookie-banner"
  class="fixed inset-x-0 bottom-0 z-50 hidden border-t border-line bg-surface p-4 shadow-none"
  role="region"
  aria-label="Cookieの利用について"
>
  <div class="mx-auto flex max-w-[1200px] flex-col items-start gap-3 md:flex-row md:items-center md:justify-between">
    <p class="text-sm text-ink-muted">
      当サイトでは、サイト改善のためにCookieを使用したアクセス解析を行っています。詳しくは<a
        href="/privacy"
        class="underline underline-offset-2">プライバシーポリシー</a
      >をご覧ください。
    </p>
    <div class="flex shrink-0 gap-3">
      <button
        id="cookie-decline"
        class="h-11 rounded-md border border-line px-5 text-sm text-ink-muted transition hover:border-ink-muted"
      >
        同意しない
      </button>
      <button
        id="cookie-accept"
        class="h-11 rounded-md bg-brand px-5 text-sm font-medium text-white transition hover:bg-brand-strong"
      >
        同意する
      </button>
    </div>
  </div>
</div>

<script>
  // TODO: GA4 測定ID確定後に差し替え（§13）
  const GA_MEASUREMENT_ID = 'G-XXXXXXXXXX';
  const KEY = 'cookie-consent';

  function loadGA() {
    if (GA_MEASUREMENT_ID === 'G-XXXXXXXXXX') return; // 未設定の間は読み込まない
    const s = document.createElement('script');
    s.async = true;
    s.src = `https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`;
    document.head.appendChild(s);
    window.dataLayer = window.dataLayer || [];
    window.gtag = function gtag() {
      window.dataLayer.push(arguments);
    };
    window.gtag('js', new Date());
    window.gtag('config', GA_MEASUREMENT_ID);
  }

  const banner = document.getElementById('cookie-banner')!;
  const stored = localStorage.getItem(KEY);
  if (stored === 'accepted') {
    loadGA();
  } else if (!stored) {
    banner.classList.remove('hidden');
  }

  document.getElementById('cookie-accept')!.addEventListener('click', () => {
    localStorage.setItem(KEY, 'accepted');
    banner.classList.add('hidden');
    loadGA();
  });
  document.getElementById('cookie-decline')!.addEventListener('click', () => {
    localStorage.setItem(KEY, 'declined');
    banner.classList.add('hidden');
  });
</script>
