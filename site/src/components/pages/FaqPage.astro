---
// FAQ全文本体（§6.5）：カテゴリ別アコーディオン + FAQPage構造化データ
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../SectionHeading.astro';
import Accordion from '../Accordion.astro';
import CTABand from '../CTABand.astro';
import { faqCategories } from '../../content/faq';
import { copy } from '../../content/copy';
import { ui } from '../../content/ui';
import { siteCommon } from '../../content/site';
import { localizePath } from '../../i18n/utils';
import type { Lang } from '../../i18n/config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const c = copy[lang];
const u = ui[lang].faq;

const meta = {
  ja: {
    title: `よくある質問｜${siteCommon.brandName}`,
    description:
      '料金・契約、作業範囲、オーストラリア特有の事情（Fresha・レビュー・LINE非対応）、進め方、成果の考え方など、よくいただくご質問にお答えします。',
  },
  en: {
    title: `FAQ｜${siteCommon.brandName}`,
    description:
      'Answers to common questions: pricing and contracts, scope of work, how Australia differs (Fresha, reviews, no LINE), how we work, and how we think about results.',
  },
}[lang];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqCategories[lang].flatMap((cat) =>
    cat.items.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a },
    }))
  ),
};
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: ui[lang].common.breadcrumbHome, item: new URL(localizePath('/', lang), siteCommon.siteUrl).href },
    { '@type': 'ListItem', position: 2, name: u.navLabel, item: new URL(localizePath('/faq', lang), siteCommon.siteUrl).href },
  ],
};
---

<BaseLayout lang={lang} title={meta.title} description={meta.description} jsonLd={[faqLd, breadcrumbLd]}>
  <section class="px-5 pb-16 pt-32 md:pt-40 lg:px-8">
    <div class="mx-auto max-w-[880px]">
      <SectionHeading label="FAQ" heading={u.heading} lead={u.lead} />
    </div>
  </section>

  <section class="px-5 pb-24 lg:px-8">
    <div class="mx-auto max-w-[880px] space-y-12">
      {
        faqCategories[lang].map((cat, i) => (
          <div class="reveal">
            <h2 class="mb-5 text-xl">{cat.category}</h2>
            <Accordion items={cat.items} analyticsPrefix={`faq-cat${i}`} />
          </div>
        ))
      }
    </div>
  </section>

  <CTABand
    lang={lang}
    heading={c.finalCta.heading}
    sub={c.finalCta.sub}
    ctaLabel={c.finalCta.cta.label}
    ctaHref={c.finalCta.cta.href}
    ctaLocation="faq-band"
  />
</BaseLayout>
