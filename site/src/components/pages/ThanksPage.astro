---
// フォーム送信完了本体（§4.3）
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../CTAButton.astro';
import { ui } from '../../content/ui';
import { siteCommon } from '../../content/site';
import type { Lang } from '../../i18n/config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const u = ui[lang].thanks;

const meta = {
  ja: { title: `送信完了｜${siteCommon.brandName}`, description: 'お問い合わせありがとうございます。1〜2営業日以内にご返信いたします。' },
  en: { title: `Thank you｜${siteCommon.brandName}`, description: 'Thanks for reaching out. We’ll reply within 1–2 business days.' },
}[lang];
---

<BaseLayout lang={lang} title={meta.title} description={meta.description}>
  <section class="flex min-h-[70vh] items-center px-5 pb-24 pt-32 lg:px-8">
    <div class="mx-auto max-w-[600px] text-center">
      <svg class="mx-auto h-14 w-14 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <circle cx="12" cy="12" r="10"></circle>
        <path d="m8 12.5 2.5 2.5L16 9"></path>
      </svg>
      <h1 class="mt-6 text-[32px]">{u.heading}</h1>
      <p class="mt-5 text-ink-muted">
        {u.body1}<strong class="text-ink">{u.bodyStrong}</strong>{u.body2}<br />
        {u.body3}<a href={`mailto:${siteCommon.email}`} class="text-brand underline underline-offset-2">{siteCommon.email}</a>{u.body4}
      </p>
      <CTAButton href="/" lang={lang} variant="secondary" ctaLocation="thanks" class="mt-10">
        {u.back}
      </CTAButton>
    </div>
  </section>
</BaseLayout>
