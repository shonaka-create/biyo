---
// サービス詳細本体（§5.1）
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../SectionHeading.astro';
import ServicePillars from '../ServicePillars.astro';
import CTABand from '../CTABand.astro';
import { copy } from '../../content/copy';
import { ui } from '../../content/ui';
import { siteCommon } from '../../content/site';
import { localizePath } from '../../i18n/utils';
import type { Lang } from '../../i18n/config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const c = copy[lang];
const u = ui[lang].service;

const meta = {
  ja: {
    title: `サービス内容｜${siteCommon.brandName}`,
    description:
      'SNS（Instagram）運用と、Webサイトの制作・運用。私たちが何をするかを具体的にご説明します。業種は問いません。ゴールドコースト・日豪2拠点・日英バイリンガル体制。',
  },
  en: {
    title: `Services｜${siteCommon.brandName}`,
    description:
      'Social media (Instagram) management, and building and running your website — spelled out. Any industry. Gold Coast, Japan + Australia, fully bilingual.',
  },
}[lang];

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: lang === 'ja' ? 'SNS運用・Web制作・運用サービス' : 'Social media & web design service',
  provider: { '@type': 'Organization', name: siteCommon.brandName },
  areaServed: ['Gold Coast'],
  description: c.services.lead,
};
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: ui[lang].common.breadcrumbHome, item: new URL(localizePath('/', lang), siteCommon.siteUrl).href },
    { '@type': 'ListItem', position: 2, name: u.navLabel, item: new URL(localizePath('/service', lang), siteCommon.siteUrl).href },
  ],
};
---

<BaseLayout lang={lang} title={meta.title} description={meta.description} jsonLd={[serviceLd, breadcrumbLd]}>
  <section class="px-5 pb-16 pt-32 md:pt-40 lg:px-8">
    <div class="mx-auto max-w-[1200px]">
      <SectionHeading label={c.services.label} heading={u.heading} lead={u.lead} />
    </div>
  </section>

  <section class="bg-surface px-5 py-20 md:py-28 lg:px-8">
    <div class="mx-auto max-w-[1200px]">
      <SectionHeading label={u.scopeLabel} heading={u.scopeHeading} lead={u.scopeLead} />
      <div class="reveal mt-12">
        <ServicePillars lang={lang} />
      </div>
      <p class="reveal mt-8 rounded-lg bg-surface-cream px-6 py-5 text-sm text-ink-muted">{c.services.note}</p>
    </div>
  </section>

  <CTABand
    lang={lang}
    heading={c.finalCta.heading}
    sub={c.finalCta.sub}
    ctaLabel={c.finalCta.cta.label}
    ctaHref={c.finalCta.cta.href}
    ctaLocation="service-band"
  />
</BaseLayout>
