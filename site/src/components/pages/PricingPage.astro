---
// 料金詳細本体（§6.2）
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../SectionHeading.astro';
import PlanCard from '../PlanCard.astro';
import SitePackageCard from '../SitePackageCard.astro';
import Accordion from '../Accordion.astro';
import CTABand from '../CTABand.astro';
import { plans, planNotes, options, pricingFaq } from '../../content/plans';
import { copy } from '../../content/copy';
import { ui } from '../../content/ui';
import { siteCommon } from '../../content/site';
import { localizePath } from '../../i18n/utils';
import type { Lang } from '../../i18n/config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const c = copy[lang];
const u = ui[lang].pricing;

const meta = {
  ja: {
    title: `料金プラン｜${siteCommon.brandName}`,
    description:
      'SNS運用・Web制作の料金一覧。SNS運用は月額3プラン（Plan A/B/C）、サイト制作は別料金。撮影同行などのオプションも含め、追加費用は契約前にすべてお伝えします。',
  },
  en: {
    title: `Pricing｜${siteCommon.brandName}`,
    description:
      'Pricing for social media management and web design. Social media is a monthly plan (A/B/C); website builds are priced separately. Add-ons like on-site shoots are clear, with every extra cost shared before you sign.',
  },
}[lang];

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: ui[lang].common.breadcrumbHome, item: new URL(localizePath('/', lang), siteCommon.siteUrl).href },
    { '@type': 'ListItem', position: 2, name: u.navLabel, item: new URL(localizePath('/pricing', lang), siteCommon.siteUrl).href },
  ],
};
---

<BaseLayout lang={lang} title={meta.title} description={meta.description} jsonLd={[breadcrumbLd]}>
  <section class="px-5 pb-16 pt-32 md:pt-40 lg:px-8">
    <div class="mx-auto max-w-[1200px]">
      <SectionHeading label="Pricing" heading={u.heading} lead={u.lead} />
    </div>
  </section>

  <section class="px-5 pb-20 lg:px-8">
    <div class="mx-auto max-w-[1200px]">
      <SectionHeading label={u.snsLabel} heading={u.snsHeading} lead={u.snsLead} />
      <div class="mt-12 grid gap-8 lg:grid-cols-3 lg:gap-6">
        {plans[lang].map((plan) => <PlanCard plan={plan} lang={lang} />)}
      </div>
    </div>
  </section>

  <section class="bg-surface px-5 py-20 md:py-28 lg:px-8">
    <div class="mx-auto max-w-[880px]">
      <SectionHeading label={u.siteLabel} heading={u.siteHeading} lead={u.siteLead} />
      <div class="mt-10">
        <SitePackageCard lang={lang} />
      </div>
      <div class="reveal mt-8 space-y-2 text-center text-sm text-ink-muted">
        {planNotes[lang].map((n) => <p class="whitespace-pre-line">{n}</p>)}
      </div>
    </div>
  </section>

  <section class="px-5 py-20 md:py-28 lg:px-8">
    <div class="mx-auto max-w-[880px]">
      <SectionHeading label={u.optionsLabel} heading={u.optionsHeading} lead={u.optionsLead} />
      <div class="reveal mt-10 overflow-hidden rounded-lg border border-line">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="border-b border-line bg-surface-cream">
              <th scope="col" class="px-5 py-3.5 font-medium">{u.tableOption}</th>
              <th scope="col" class="px-5 py-3.5 font-medium">{u.tablePrice}</th>
              <th scope="col" class="hidden px-5 py-3.5 font-medium md:table-cell">{u.tableNote}</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-line bg-canvas">
            {
              options[lang].map((o) => (
                <tr>
                  <td class="px-5 py-4 font-medium">{o.name}</td>
                  <td class="px-5 py-4 text-ink-muted">{o.price}</td>
                  <td class="hidden px-5 py-4 text-ink-muted md:table-cell">{o.note}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="bg-surface px-5 py-20 md:py-28 lg:px-8">
    <div class="mx-auto max-w-[880px]">
      <SectionHeading label={u.faqLabel} heading={u.faqHeading} />
      <div class="reveal mt-10">
        <Accordion items={pricingFaq[lang]} analyticsPrefix="pricing" />
      </div>
    </div>
  </section>

  <CTABand
    lang={lang}
    heading={u.bandHeading}
    sub={u.bandSub}
    ctaLabel={c.finalCta.cta.label}
    ctaHref={c.finalCta.cta.href}
    ctaLocation="pricing-band"
  />
</BaseLayout>
