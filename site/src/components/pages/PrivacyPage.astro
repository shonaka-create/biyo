---
// プライバシーポリシー本体（§6.7 / §15）
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ui } from '../../content/ui';
import { siteCommon } from '../../content/site';
import { privacySections, privacyIntro } from '../../content/privacy';
import type { Lang } from '../../i18n/config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const u = ui[lang].privacy;
const sections = privacySections[lang];

// {brand} / {email} を実値へ置換
const fill = (s?: string) =>
  (s ?? '').replaceAll('{brand}', siteCommon.brandName).replaceAll('{email}', siteCommon.email);
---

<BaseLayout lang={lang} title={`${u.title}｜${siteCommon.brandName}`} description={privacyIntro[lang]}>
  <article class="px-5 pb-24 pt-32 md:pt-40 lg:px-8">
    <div class="mx-auto max-w-[760px]">
      <h1 class="text-[32px]">{u.title}</h1>
      <p class="mt-4 text-sm text-ink-muted">{u.updated}</p>

      <div class="mt-10 space-y-10 text-[15px] leading-loose text-ink-muted">
        {
          sections.map((sec) => (
            <section>
              <h2 class="mb-3 text-xl text-ink">{sec.heading}</h2>
              {sec.body && <p set:html={fill(sec.body).replace(
                siteCommon.email,
                `<a href="mailto:${siteCommon.email}" class="text-brand underline underline-offset-2">${siteCommon.email}</a>`
              )} />}
              {sec.list && (
                <ul class="mt-3 list-disc space-y-1 pl-6">
                  {sec.list.map((li) => <li>{li}</li>)}
                </ul>
              )}
            </section>
          ))
        }
        <!-- TODO: 事業者表記（屋号・所在地・代表者名）を確定後に追記（§15） -->
      </div>
    </div>
  </article>
</BaseLayout>
