---
// トップページ本体（§6.1）：S1〜S15。/（ja）と /en/（en）の両ルートから lang を受けて描画。
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../CTAButton.astro';
import SectionHeading from '../SectionHeading.astro';
import ImagePlaceholder from '../ImagePlaceholder.astro';
import ServicePillars from '../ServicePillars.astro';
import PlanCard from '../PlanCard.astro';
import Stepper from '../Stepper.astro';
import Accordion from '../Accordion.astro';
import CTABand from '../CTABand.astro';
import { siteCommon } from '../../content/site';
import { copy } from '../../content/copy';
import { plans, sitePlans, planNotes } from '../../content/plans';
import { faqCategories } from '../../content/faq';
import { works } from '../../content/works';
import { ui } from '../../content/ui';
import { localizePath } from '../../i18n/utils';
import type { Lang } from '../../i18n/config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const c = copy[lang];
const u = ui[lang].home;
const pricingUi = ui[lang].pricing;

const meta = {
  ja: {
    title: `ゴールドコーストのSNS運用・Web制作｜${siteCommon.brandName}`,
    description:
      'ゴールドコーストで事業を営むオーナー向けに、Instagramを中心としたSNS運用と、Webサイトの制作・運用を、日本品質で一貫サポート。業種は問いません。日豪2拠点・日英バイリンガル体制。',
  },
  en: {
    title: `Social media & web for Gold Coast businesses｜${siteCommon.brandName}`,
    description:
      'Japanese-quality social media management and website builds for businesses on the Gold Coast — any industry. Instagram-led content and your website, run end to end. Japan + Australia, fully bilingual.',
  },
}[lang];

const featuredFaq = faqCategories[lang]
  .flatMap((cat) => cat.items)
  .filter((i) => i.featured)
  .slice(0, 6);

// S1 ヒーロー背景スライドショー（3枚クロスフェード）：Web集客・マーケティングの雰囲気
const heroSlides = [
  'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=1800&q=80&fit=crop',
  'https://images.unsplash.com/photo-1542744173-8e7e53415bb0?w=1800&q=80&fit=crop',
  'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=1800&q=80&fit=crop',
];
---

<BaseLayout lang={lang} title={meta.title} description={meta.description} transparentHeader>
  <!-- S1. ヒーロー（背景3枚クロスフェード＋黒オーバーレイ） -->
  <section class="hero relative isolate flex min-h-[92vh] items-center overflow-hidden">
    <!-- 背景スライドショー -->
    <div class="absolute inset-0 -z-20" aria-hidden="true">
      {
        heroSlides.map((src, i) => (
          <img
            src={src}
            alt=""
            data-hero-slide
            class:list={[
              'hero-slide absolute inset-0 h-full w-full object-cover',
              i === 0 ? 'opacity-100' : 'opacity-0',
            ]}
            loading={i === 0 ? 'eager' : 'lazy'}
            decoding="async"
            fetchpriority={i === 0 ? 'high' : undefined}
          />
        ))
      }
    </div>
    <!-- 黒の透明オーバーレイ（文字を浮き上がらせる） -->
    <div
      class="absolute inset-0 -z-10 bg-gradient-to-br from-black/75 via-black/55 to-black/30"
      aria-hidden="true"
    ></div>
    <div class="absolute inset-0 -z-10 bg-black/15" aria-hidden="true"></div>

    <div class="mx-auto w-full max-w-[1200px] px-5 pb-28 pt-36 md:pb-32 md:pt-44 lg:px-8">
      <div class="max-w-[720px]">
        <span class="inline-flex items-center gap-2 rounded-full border border-white/25 bg-white/10 px-4 py-1.5 text-xs font-medium tracking-wide text-white backdrop-blur">
          <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
          {c.hero.eyebrow}
        </span>

        <h1 class="mt-6 text-[34px] leading-[1.22] text-white drop-shadow-sm md:text-[48px] lg:text-[56px]">
          <span class="block" set:html={c.hero.heading.lead.replace(/\n/g, '<br />')} />
          <span class="mt-1 block w-fit underline decoration-accent decoration-[3px] underline-offset-[10px]">
            {c.hero.heading.accent}
          </span>
        </h1>

        <p class="mt-6 max-w-[560px] text-[17px] leading-relaxed text-white/85">{c.hero.sub}</p>

        <div class="mt-9 flex flex-col gap-4 sm:flex-row sm:items-center">
          <CTAButton href={c.hero.ctaPrimary.href} lang={lang} variant="primary" ctaLocation="hero" class="px-8">
            {c.hero.ctaPrimary.label}
          </CTAButton>
          <CTAButton
            href={c.hero.ctaSecondary.href}
            lang={lang}
            variant="secondary"
            ctaLocation="hero-email"
            class="gap-2 !border-white/70 px-8 !text-white hover:!bg-white/10"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <path d="m3 7 9 6 9-6"></path>
            </svg>
            {c.hero.ctaSecondary.label}
          </CTAButton>
        </div>
      </div>
    </div>

    <!-- スライドインジケーター -->
    <div class="absolute bottom-6 left-1/2 z-10 flex -translate-x-1/2 gap-2.5 lg:bottom-8" aria-hidden="true">
      {
        heroSlides.map((_, i) => (
          <span
            data-hero-dot
            class:list={[
              'h-1.5 rounded-full bg-white/40 transition-all duration-500',
              i === 0 ? 'w-7 bg-white' : 'w-1.5',
            ]}
          />
        ))
      }
    </div>
  </section>

  <!-- S1.5 お悩み（課題提起） -->
  <section class="bg-surface-cream px-5 py-20 md:py-28 lg:px-8">
    <div class="mx-auto max-w-[1000px]">
      <SectionHeading label={c.concerns.label} heading={c.concerns.heading} align="center" />
      <ul class="mt-12 grid gap-5 sm:grid-cols-2">
        {
          c.concerns.items.map((item) => (
            <li class="reveal flex items-start gap-3 rounded-lg border border-line bg-canvas px-6 py-5">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-accent"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path d="m5 13 4 4L19 7" />
              </svg>
              <span class="text-[15px] leading-relaxed text-ink">{item}</span>
            </li>
          ))
        }
      </ul>
      <p class="reveal mt-10 text-center text-lg font-medium text-ink">{c.concerns.closing}</p>
    </div>
  </section>

  <!-- S2. 信頼バー（実績サマリー＋雰囲気ギャラリー） -->
  <section class="relative overflow-hidden border-y border-line bg-gradient-to-b from-surface to-canvas px-5 py-16 md:py-20 lg:px-8">
    <!-- 上端の装飾アクセントライン -->
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent/60 to-transparent" aria-hidden="true"></div>

    <div class="mx-auto max-w-[1200px]">
      <!-- 実績サマリー（番号付きで強調） -->
      <dl class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4 lg:gap-7">
        {
          c.trustBar.items.map((item, i) => (
            <div class="reveal relative flex flex-col rounded-2xl border border-line bg-canvas/60 px-7 py-8 shadow-sm transition-shadow duration-300 hover:shadow-lg">
              <span class="font-display text-5xl leading-none text-accent/30 md:text-6xl">
                {String(i + 1).padStart(2, '0')}
              </span>
              <dt class="mt-5 flex items-center gap-2 text-[11px] font-medium uppercase tracking-[0.18em] text-accent">
                <span class="h-px w-4 bg-accent/40" aria-hidden="true" />
                {item.label}
              </dt>
              <dd class="mt-3 font-display text-[22px] leading-snug text-ink md:text-[24px]">{item.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- S7. サービス内容 -->
  <section id="service" class="px-5 py-20 md:py-28 lg:px-8">
    <div class="mx-auto max-w-[1200px]">
      <SectionHeading label={c.services.label} heading={c.services.heading} lead={c.services.lead} />
      <div class="reveal mt-12">
        <ServicePillars lang={lang} />
      </div>
      <p class="reveal mt-8 rounded-lg bg-surface-cream px-6 py-5 text-sm text-ink-muted">{c.services.note}</p>
      <div class="reveal mt-8 text-center">
        <CTAButton href="/service" lang={lang} variant="text" ctaLocation="service-more">{u.serviceMore}</CTAButton>
      </div>
    </div>
  </section>

  <!-- S8. 料金プラン -->
  <section class="bg-surface-cream px-5 py-20 md:py-28 lg:px-8">
    <div class="mx-auto max-w-[1200px]">
      <SectionHeading label={u.pricingLabel} heading={u.pricingHeading} lead={u.pricingLead} align="center" />
      <h3 class="reveal mt-12 text-center font-display text-xl text-ink md:text-2xl">{pricingUi.snsHeading}</h3>
      <div class="mt-8 grid gap-8 lg:grid-cols-3 lg:gap-6">
        {plans[lang].map((plan) => <PlanCard plan={plan} lang={lang} />)}
      </div>

      <div class="reveal mx-auto mt-14 max-w-[760px]">
        <h3 class="text-center font-display text-xl text-ink md:text-2xl">{pricingUi.siteHeading}</h3>
        <p class="mt-2 whitespace-pre-line text-center text-sm text-ink-muted">{pricingUi.siteLead}</p>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          {
            sitePlans[lang].map((s) => (
              <div class="rounded-lg border border-line bg-canvas px-6 py-5">
                <p class="font-medium text-ink">{s.scope}</p>
                <p class="mt-1 font-display text-2xl text-ink">{s.price}</p>
                <p class="mt-2 text-sm text-ink-muted">{s.note}</p>
              </div>
            ))
          }
        </div>
      </div>

      <div class="reveal mt-10 space-y-2 text-center text-sm text-ink-muted">
        {planNotes[lang].map((n) => <p class="whitespace-pre-line">{n}</p>)}
      </div>
      <div class="reveal mt-6 text-center">
        <CTAButton href="/pricing" lang={lang} variant="text" ctaLocation="pricing-more">{u.pricingMore}</CTAButton>
      </div>
    </div>
  </section>

  <!-- S9. 導入の流れ -->
  <section class="px-5 py-20 md:py-28 lg:px-8">
    <div class="mx-auto max-w-[1200px]">
      <SectionHeading label={c.steps.label} heading={c.steps.heading} align="center" />
      <div class="mt-12">
        <Stepper items={c.steps.items} />
      </div>
    </div>
  </section>

  <!-- S10. 実績・事例 -->
  <section class="bg-surface px-5 py-20 md:py-28 lg:px-8">
    <div class="mx-auto max-w-[1200px]">
      <SectionHeading label={u.worksLabel} heading={u.worksHeading} lead={u.worksLead} />
      <div class="mt-12 grid gap-8 md:grid-cols-2">
        {
          works[lang].map((work) => (
            <a href={localizePath(`/works/${work.slug}`, lang)} class="reveal group block rounded-lg border border-line bg-canvas p-6 transition hover:border-brand">
              <ImagePlaceholder slot_id={work.thumbSlot} label={u.thumbLabel(work.name)} ratio="4/3" />
              <p class="mt-5 text-xs tracking-widest text-ink-muted">{work.industry}｜{work.area}</p>
              <h3 class="mt-1 font-sans text-lg font-semibold transition group-hover:text-brand">{work.name}</h3>
              <p class="mt-2 text-sm text-ink-muted">{work.summary}</p>
            </a>
          ))
        }
      </div>
      <div class="reveal mt-10 text-center">
        <CTAButton href="/works" lang={lang} variant="secondary" ctaLocation="works-more">{u.worksMore}</CTAButton>
      </div>
    </div>
  </section>

  <!-- S11. お客様の声（SNS運用／サイト制作でフィルター × 横スライダー） -->
  <section class="px-5 py-20 md:py-28 lg:px-8">
    <div class="mx-auto max-w-[1200px]" data-voice-root>
      <SectionHeading label={c.testimonials.label} heading={c.testimonials.heading} align="center" />

      <!-- フィルター -->
      <div class="reveal mt-8 flex flex-wrap justify-center gap-2" role="group" aria-label={c.testimonials.heading}>
        {
          c.testimonials.filters.map((f, i) => (
            <button
              type="button"
              data-voice-filter={f.id}
              aria-pressed={i === 0 ? 'true' : 'false'}
              class:list={[
                'voice-tab rounded-full border px-5 py-2 text-sm font-medium transition',
                i === 0
                  ? 'border-brand bg-brand text-white'
                  : 'border-line bg-surface text-ink-muted hover:border-brand hover:text-brand',
              ]}
            >
              {f.label}
            </button>
          ))
        }
      </div>

      <!-- スライダー -->
      <div class="relative mt-10">
        <div class="voice-scroll reveal -mx-5 flex snap-x snap-mandatory gap-5 overflow-x-auto px-5 pb-4 lg:mx-0 lg:px-0" data-voice-track>
          {
            c.testimonials.items.map((t) => (
              <figure
                data-voice-card
                data-category={t.category}
                class="flex shrink-0 basis-[85%] snap-start flex-col rounded-lg border border-line bg-surface p-7 sm:basis-[360px]"
              >
                <blockquote class="text-[15px] leading-relaxed text-ink-muted">{t.comment}</blockquote>
                <figcaption class="mt-5 border-t border-line pt-4">
                  <p class="text-sm font-medium">{t.name}</p>
                  <p class="text-xs text-ink-muted">{t.shop}</p>
                </figcaption>
              </figure>
            ))
          }
        </div>

        <!-- 矢印（PCのみ・スクロール可能なときだけ表示） -->
        <button
          type="button"
          data-voice-prev
          aria-label="前へ"
          class="absolute -left-4 top-1/2 hidden h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-line bg-canvas text-ink shadow-sm transition hover:border-brand hover:text-brand disabled:pointer-events-none disabled:opacity-0 lg:flex"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6" /></svg>
        </button>
        <button
          type="button"
          data-voice-next
          aria-label="次へ"
          class="absolute -right-4 top-1/2 hidden h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-line bg-canvas text-ink shadow-sm transition hover:border-brand hover:text-brand disabled:pointer-events-none disabled:opacity-0 lg:flex"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6" /></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- S12. チーム紹介 -->
  <section class="bg-surface-cream px-5 py-20 md:py-28 lg:px-8">
    <div class="mx-auto max-w-[1200px]">
      <SectionHeading label={c.team.label} heading={c.team.heading} lead={c.team.lead} align="center" />
      <div class="mx-auto mt-12 grid max-w-[880px] gap-8 md:grid-cols-2">
        {
          c.team.members.map((member) => (
            <div class="reveal rounded-lg bg-surface p-7 text-center">
              <ImagePlaceholder slot_id={member.slot} label={u.portraitLabel(member.role)} ratio="1/1" class="mx-auto w-40 rounded-full" />
              <h3 class="mt-5 font-sans text-lg font-semibold">{member.name}</h3>
              <p class="mt-1 text-sm text-brand">{member.role}</p>
              <p class="mt-1 text-xs text-ink-muted">{member.location}</p>
              <p class="mt-4 text-sm text-ink-muted">{member.message}</p>
            </div>
          ))
        }
      </div>
      <div class="reveal mt-10 text-center">
        <CTAButton href="/about" lang={lang} variant="text" ctaLocation="about-more">{u.aboutMore}</CTAButton>
      </div>
    </div>
  </section>

  <!-- S13. FAQ（抜粋） -->
  <section class="px-5 py-20 md:py-28 lg:px-8">
    <div class="mx-auto max-w-[880px]">
      <SectionHeading label={u.faqLabel} heading={u.faqHeading} align="center" />
      <div class="reveal mt-12">
        <Accordion items={featuredFaq} analyticsPrefix="top" />
      </div>
      <div class="reveal mt-8 text-center">
        <CTAButton href="/faq" lang={lang} variant="text" ctaLocation="faq-more">{u.faqMore}</CTAButton>
      </div>
    </div>
  </section>

  <!-- S14. 最終CTAバンド -->
  <CTABand
    lang={lang}
    heading={c.finalCta.heading}
    sub={c.finalCta.sub}
    ctaLabel={c.finalCta.cta.label}
    ctaHref={c.finalCta.cta.href}
    ctaLocation="final-band"
  />
</BaseLayout>

<style>
  /* ヒーロー背景のクロスフェード */
  .hero-slide {
    transition: opacity 1400ms ease-in-out;
    will-change: opacity;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-slide {
      transition: none;
    }
  }

  /* お客様の声：横スクロール（控えめなスクロールバー＋慣性スクロール） */
  .voice-scroll {
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
  }
  .voice-scroll::-webkit-scrollbar {
    height: 6px;
  }
  .voice-scroll::-webkit-scrollbar-thumb {
    background: var(--color-line);
    border-radius: 9999px;
  }
</style>

<script>
  // S1 ヒーロー：背景3枚を一定間隔でクロスフェード
  function initHeroSlideshow() {
    const hero = document.querySelector('.hero');
    if (!hero) return;
    const slides = Array.from(hero.querySelectorAll<HTMLElement>('[data-hero-slide]'));
    const dots = Array.from(hero.querySelectorAll<HTMLElement>('[data-hero-dot]'));
    if (slides.length < 2) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    let current = 0;
    const INTERVAL = 5500;

    setInterval(() => {
      const next = (current + 1) % slides.length;
      slides[current].classList.replace('opacity-100', 'opacity-0');
      slides[next].classList.replace('opacity-0', 'opacity-100');
      dots[current]?.classList.remove('w-7', 'bg-white');
      dots[current]?.classList.add('w-1.5');
      dots[next]?.classList.remove('w-1.5');
      dots[next]?.classList.add('w-7', 'bg-white');
      current = next;
    }, INTERVAL);
  }

  initHeroSlideshow();
  document.addEventListener('astro:page-load', initHeroSlideshow);

  // S11 お客様の声：カテゴリーフィルター × 横スライダー
  function initVoice() {
    const root = document.querySelector<HTMLElement>('[data-voice-root]');
    if (!root) return;
    const track = root.querySelector<HTMLElement>('[data-voice-track]');
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-voice-filter]'));
    const cards = Array.from(root.querySelectorAll<HTMLElement>('[data-voice-card]'));
    const prev = root.querySelector<HTMLButtonElement>('[data-voice-prev]');
    const next = root.querySelector<HTMLButtonElement>('[data-voice-next]');
    if (!track) return;

    const activeCls = ['border-brand', 'bg-brand', 'text-white'];
    const idleCls = ['border-line', 'bg-surface', 'text-ink-muted'];

    const updateArrows = () => {
      if (!prev || !next) return;
      const max = track.scrollWidth - track.clientWidth - 1;
      prev.disabled = track.scrollLeft <= 0;
      next.disabled = track.scrollLeft >= max;
    };

    const applyFilter = (id: string) => {
      cards.forEach((card) => {
        const show = id === 'all' || card.dataset.category === id;
        card.classList.toggle('hidden', !show);
      });
      track.scrollTo({ left: 0 });
      requestAnimationFrame(updateArrows);
    };

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        tabs.forEach((t) => {
          const on = t === tab;
          t.setAttribute('aria-pressed', String(on));
          t.classList.toggle(activeCls[0], on);
          t.classList.toggle(activeCls[1], on);
          t.classList.toggle(activeCls[2], on);
          idleCls.forEach((c) => t.classList.toggle(c, !on));
        });
        applyFilter(tab.dataset.voiceFilter || 'all');
      });
    });

    const step = () => {
      const card = cards.find((c) => !c.classList.contains('hidden'));
      return card ? card.getBoundingClientRect().width + 20 : track.clientWidth * 0.8;
    };
    prev?.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));
    next?.addEventListener('click', () => track.scrollBy({ left: step(), behavior: 'smooth' }));
    track.addEventListener('scroll', updateArrows, { passive: true });
    window.addEventListener('resize', updateArrows, { passive: true });
    updateArrows();
  }

  initVoice();
  document.addEventListener('astro:page-load', initVoice);
</script>
